---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Paramount World Records — Welcome" showChrome={false}>
	<main class="splash">
		<div class="splash-mist" aria-hidden="true"></div>
		<div class="splash-vignette" aria-hidden="true"></div>
		<div class="splash-inner">
			<p class="splash-tag">Elite global record authority</p>
			<h1 class="splash-title">
				Paramount<span class="stoplight" aria-hidden="true">.</span>
				<span class="splash-title-sub">World records</span>
			</h1>
			<p class="splash-line">
				Authorisation · Adjudication · Verification · Certification · Publishing
			</p>
			<a class="splash-enter" href="/home">Enter</a>
			<p class="splash-hint">Official registry — private entry</p>
		</div>
	</main>

	<style>
		.splash {
			min-height: 100vh;
			display: grid;
			place-items: center;
			padding: 2rem 1.25rem;
			position: relative;
			background: #f4f6fb;
			overflow: hidden;
		}

		.splash-mist {
			position: absolute;
			left: 50%;
			top: 38%;
			transform: translate(-50%, -50%);
			width: min(120vw, 800px);
			height: min(100vw, 560px);
			background: radial-gradient(circle, rgba(79, 70, 229, 0.12) 0%, transparent 70%);
			pointer-events: none;
		}

		.splash-vignette {
			position: absolute;
			inset: 0;
			pointer-events: none;
			background: radial-gradient(ellipse 85% 75% at 50% 45%, transparent 35%, rgba(15, 23, 42, 0.04) 100%);
		}

		.splash-inner {
			position: relative;
			z-index: 1;
			text-align: center;
			max-width: min(560px, 94vw);
			padding: clamp(2.5rem, 6vw, 4rem);
			border: 1px solid #e2e8f0;
			border-radius: 16px;
			background: #ffffff;
			box-shadow: 0 24px 56px rgba(15, 23, 42, 0.08);
		}

		.splash-inner::before {
			content: "";
			position: absolute;
			inset: 0;
			border-radius: 16px;
			background: radial-gradient(circle at 50% 0%, rgba(79, 70, 229, 0.06) 0%, transparent 52%);
			pointer-events: none;
		}

		.splash-inner > * {
			position: relative;
			z-index: 1;
		}

		.splash-tag {
			margin: 0 0 1.25rem;
			font-size: 0.8125rem;
			font-family: "Plus Jakarta Sans", system-ui, sans-serif;
			font-weight: 600;
			letter-spacing: 0.02em;
			text-transform: none;
			color: #4f46e5;
		}

		.splash-title {
			margin: 0 0 1rem;
			font-size: clamp(2.25rem, 8vw, 3.75rem);
			font-family: "Plus Jakarta Sans", system-ui, sans-serif;
			font-weight: 800;
			line-height: 1.08;
			text-transform: none;
			letter-spacing: -0.03em;
			color: #0f172a;
		}

		.splash-title-sub {
			display: block;
			margin-top: 0.2em;
			font-size: 0.45em;
			font-weight: 700;
			letter-spacing: -0.02em;
			color: #64748b;
		}

		.splash-line {
			margin: 0 0 2rem;
			color: #64748b;
			font-family: Inter, system-ui, sans-serif;
			font-size: 0.875rem;
			letter-spacing: 0.02em;
			line-height: 1.65;
			text-transform: none;
		}

		.splash-enter {
			display: inline-block;
			padding: 0.95rem 2.5rem;
			text-decoration: none;
			border-radius: 9999px;
			font-family: "Plus Jakarta Sans", system-ui, sans-serif;
			font-weight: 600;
			text-transform: none;
			font-size: 0.9375rem;
			letter-spacing: 0;
			background: #4f46e5;
			color: #ffffff;
			border: 1px solid #4f46e5;
			box-shadow: 0 8px 24px rgba(79, 70, 229, 0.25);
			transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease, border-color 0.25s ease;
		}

		.splash-enter:hover {
			transform: translateY(-2px);
			background: #4338ca;
			border-color: #4338ca;
			box-shadow: 0 12px 32px rgba(79, 70, 229, 0.3);
		}

		.splash-hint {
			margin: 1.75rem 0 0;
			font-size: 0.8125rem;
			font-family: Inter, system-ui, sans-serif;
			font-weight: 400;
			color: #94a3b8;
			letter-spacing: 0;
			text-transform: none;
		}
	</style>
</Layout>
