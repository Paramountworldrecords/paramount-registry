---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Paramount World Records — Welcome" showChrome={false}>
	<main class="splash">
		<div class="splash-mist" aria-hidden="true"></div>
		<div class="splash-vignette" aria-hidden="true"></div>
		<div class="splash-inner">
			<p class="splash-tag">Elite global record authority</p>
			<h1 class="splash-title">
				Paramount<span class="stoplight" aria-hidden="true">.</span>
				<span class="splash-title-sub">World records</span>
			</h1>
			<p class="splash-line">
				Authorisation · Adjudication · Verification · Certification · Publishing
			</p>
			<a class="splash-enter" href="/home">Enter</a>
			<p class="splash-hint">Official registry — private entry</p>
		</div>
	</main>

	<style>
		.splash {
			min-height: 100vh;
			display: grid;
			place-items: center;
			padding: 2rem 1.25rem;
			position: relative;
			background: #080808;
			overflow: hidden;
		}

		.splash-mist {
			position: absolute;
			left: 50%;
			top: 38%;
			transform: translate(-50%, -50%);
			width: min(120vw, 800px);
			height: min(100vw, 560px);
			background: radial-gradient(circle, rgba(0, 201, 167, 0.15) 0%, transparent 70%);
			pointer-events: none;
		}

		.splash-vignette {
			position: absolute;
			inset: 0;
			pointer-events: none;
			background: radial-gradient(ellipse 80% 70% at 50% 50%, transparent 20%, rgba(0, 0, 0, 0.5) 100%);
		}

		.splash-inner {
			position: relative;
			z-index: 1;
			text-align: center;
			max-width: min(560px, 94vw);
			padding: clamp(2.5rem, 6vw, 4rem);
			border: 1px solid #1f1f1f;
			border-radius: 24px;
			background: #121212;
			box-shadow: 0 24px 64px rgba(0, 0, 0, 0.45);
		}

		.splash-inner::before {
			content: "";
			position: absolute;
			inset: 0;
			border-radius: 24px;
			background: radial-gradient(circle at 50% 0%, rgba(0, 201, 167, 0.1) 0%, transparent 50%);
			pointer-events: none;
		}

		.splash-inner > * {
			position: relative;
			z-index: 1;
		}

		.splash-tag {
			margin: 0 0 1.25rem;
			font-size: 0.62rem;
			font-family: Montserrat, system-ui, sans-serif;
			font-weight: 300;
			letter-spacing: 0.2em;
			text-transform: uppercase;
			color: rgba(255, 255, 255, 0.5);
		}

		.splash-title {
			margin: 0 0 1rem;
			font-size: clamp(2.5rem, 10vw, 4.5rem);
			font-family: Anton, Impact, sans-serif;
			font-weight: 400;
			line-height: 0.95;
			text-transform: uppercase;
			letter-spacing: -0.04em;
			color: #ffffff;
		}

		.splash-title-sub {
			display: block;
			margin-top: 0.12em;
			font-size: 0.42em;
			letter-spacing: 0.18em;
		}

		.splash-line {
			margin: 0 0 2rem;
			color: rgba(255, 255, 255, 0.65);
			font-family: Inter, system-ui, sans-serif;
			font-size: 0.78rem;
			letter-spacing: 0.14em;
			line-height: 1.6;
			text-transform: uppercase;
		}

		.splash-enter {
			display: inline-block;
			padding: 1rem 2.75rem;
			text-decoration: none;
			border-radius: 24px;
			font-family: Montserrat, system-ui, sans-serif;
			font-weight: 500;
			text-transform: uppercase;
			font-size: 0.65rem;
			letter-spacing: 0.2em;
			background: #ffffff;
			color: #080808;
			border: 1px solid #ffffff;
			box-shadow: 0 0 36px rgba(0, 201, 167, 0.12);
			transition: transform 0.25s ease, box-shadow 0.25s ease;
		}

		.splash-enter:hover {
			transform: translateY(-2px);
			box-shadow: 0 12px 40px rgba(0, 201, 167, 0.2);
		}

		.splash-hint {
			margin: 1.75rem 0 0;
			font-size: 0.6rem;
			font-family: Montserrat, system-ui, sans-serif;
			font-weight: 300;
			color: rgba(255, 255, 255, 0.4);
			letter-spacing: 0.2em;
			text-transform: uppercase;
		}
	</style>
</Layout>
