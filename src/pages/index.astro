---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Paramount World Records — Welcome" showChrome={false}>
	<main class="splash">
		<div class="splash-vignette" aria-hidden="true"></div>
		<div class="splash-inner">
			<p class="splash-tag">Elite Global Record Authority</p>
			<h1 class="splash-title">Paramount <span>World Records</span></h1>
			<p class="splash-line">Authorisation · Adjudication · Verification · Certification · Publishing</p>
			<a class="splash-enter" href="/home">Enter</a>
			<p class="splash-hint">Official registry — private entry</p>
		</div>
	</main>

	<style>
		/* Add /public/fonts/skylens-italic.woff2 for exact SKYLENS ITALIC rendering. */
		@font-face {
			font-family: "Skylens Italic";
			src: url("/fonts/skylens-italic.woff2") format("woff2");
			font-style: italic;
			font-weight: 400;
			font-display: swap;
		}

		.splash {
			min-height: 100vh;
			display: grid;
			place-items: center;
			padding: 2rem 1.25rem;
			position: relative;
			/* Same layered wash + forest base as `body` in Layout.astro */
			background:
				radial-gradient(ellipse 130% 85% at 50% -18%, rgba(255, 252, 247, 0.16) 0%, transparent 55%),
				radial-gradient(ellipse 75% 65% at 0% 45%, rgba(255, 248, 235, 0.07) 0%, transparent 48%),
				radial-gradient(ellipse 70% 55% at 100% 55%, rgba(212, 175, 55, 0.11) 0%, transparent 52%),
				radial-gradient(circle at 50% 110%, rgba(180, 200, 175, 0.06) 0%, transparent 45%),
				linear-gradient(168deg, #1a3d2e 0%, #0f2619 40%, #06140e 100%);
		}

		.splash-vignette {
			position: absolute;
			inset: 0;
			pointer-events: none;
			background: radial-gradient(
				ellipse 70% 60% at 50% 50%,
				transparent 0%,
				rgba(4, 18, 12, 0.52) 100%
			);
		}

		.splash-inner {
			position: relative;
			z-index: 1;
			text-align: center;
			max-width: 560px;
		}

		.splash-tag {
			margin: 0 0 0.5rem;
			font-size: 0.72rem;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			color: #9cb8aa;
		}

		.splash-title {
			margin: 0 0 0.75rem;
			font-size: clamp(2.45rem, 8vw, 4.6rem);
			font-family: "Skylens Italic", "Cormorant Garamond", Georgia, serif;
			font-style: italic;
			font-weight: 700;
			line-height: 1.02;
			text-transform: uppercase;
			letter-spacing: 0.03em;
			color: transparent;
			-webkit-text-stroke: 1px rgba(241, 213, 146, 0.9);
			text-stroke: 1px rgba(241, 213, 146, 0.9);
			text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);
		}

		.splash-title span {
			display: block;
			color: transparent;
			-webkit-text-stroke: 1px rgba(241, 213, 146, 0.75);
			text-stroke: 1px rgba(241, 213, 146, 0.75);
		}

		.splash-line {
			margin: 0 0 2rem;
			color: #a8b0a8;
			font-size: 0.88rem;
			letter-spacing: 0.06em;
		}

		.splash-enter {
			display: inline-block;
			padding: 1rem 2.75rem;
			text-decoration: none;
			border-radius: 3px;
			font-weight: 700;
			text-transform: uppercase;
			font-size: 0.88rem;
			letter-spacing: 0.2em;
			background: linear-gradient(145deg, #ece9e4 0%, #b0aca4 45%, #5e5c57 100%);
			color: #0a0a0a;
			box-shadow:
				0 4px 20px rgba(0, 0, 0, 0.35),
				inset 0 1px 0 rgba(255, 255, 255, 0.35);
			transition: transform 0.2s ease, box-shadow 0.2s ease;
		}

		.splash-enter:hover {
			transform: translateY(-2px);
			box-shadow:
				0 8px 28px rgba(0, 0, 0, 0.4),
				inset 0 1px 0 rgba(255, 255, 255, 0.4);
		}

		.splash-hint {
			margin: 1.5rem 0 0;
			font-size: 0.75rem;
			color: #6a756e;
			letter-spacing: 0.04em;
		}
	</style>
</Layout>
