---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Paramount World Records — Welcome" showChrome={false}>
	<main class="splash">
		<div class="splash-vignette" aria-hidden="true"></div>
		<div class="splash-inner">
			<p class="splash-tag">Elite Global Record Authority</p>
			<h1 class="splash-title">Paramount <span>World Records</span></h1>
			<p class="splash-line">Authorisation · Adjudication · Verification · Certification · Publishing</p>
			<a class="splash-enter" href="/home">Enter</a>
			<p class="splash-hint">Official registry — private entry</p>
		</div>
	</main>

	<style>
		/* Add /public/fonts/skylens-italic.woff2 for exact SKYLENS ITALIC rendering. */
		@font-face {
			font-family: "Skylens Italic";
			src: url("/fonts/skylens-italic.woff2") format("woff2");
			font-style: italic;
			font-weight: 400;
			font-display: swap;
		}

		.splash {
			min-height: 100vh;
			display: grid;
			place-items: center;
			padding: 3rem 1.5rem;
			position: relative;
			background:
				radial-gradient(ellipse 90% 70% at 50% 0%, rgba(196, 197, 186, 0.45) 0%, transparent 55%),
				#e4e4de;
		}

		.splash-vignette {
			position: absolute;
			inset: 0;
			pointer-events: none;
			background: radial-gradient(
				ellipse 75% 65% at 50% 50%,
				transparent 35%,
				rgba(27, 27, 27, 0.04) 100%
			);
		}

		.splash-inner {
			position: relative;
			z-index: 1;
			text-align: center;
			max-width: 580px;
			padding: clamp(2rem, 5vw, 3.5rem);
			border: 1px solid #a3a494;
			background: linear-gradient(165deg, #c4c5ba 0%, #b8b9ae 100%);
			box-shadow: 0 16px 48px rgba(27, 27, 27, 0.07);
		}

		.splash-tag {
			margin: 0 0 1rem;
			font-size: 0.68rem;
			letter-spacing: 0.22em;
			text-transform: uppercase;
			color: #2c2c2c;
			font-family: Inter, system-ui, sans-serif;
			font-weight: 600;
		}

		.splash-title {
			margin: 0 0 1rem;
			font-size: clamp(2.2rem, 7vw, 3.75rem);
			font-family: "Playfair Display", "Skylens Italic", Georgia, serif;
			font-style: normal;
			font-weight: 600;
			line-height: 1.08;
			text-transform: none;
			letter-spacing: -0.02em;
			color: #1b1b1b;
			-webkit-text-stroke: 0;
			text-shadow: none;
		}

		.splash-title span {
			display: block;
			font-style: italic;
			color: #1b1b1b;
			margin-top: 0.15em;
		}

		.splash-line {
			margin: 0 0 2.25rem;
			color: #2c2c2c;
			font-size: 0.9rem;
			letter-spacing: 0.08em;
			line-height: 1.6;
		}

		.splash-enter {
			display: inline-block;
			padding: 1rem 2.5rem;
			text-decoration: none;
			border-radius: 2px;
			font-family: Inter, system-ui, sans-serif;
			font-weight: 600;
			text-transform: uppercase;
			font-size: 0.72rem;
			letter-spacing: 0.2em;
			background: #1b1b1b;
			color: #e4e4de;
			border: 1px solid #1b1b1b;
			box-shadow: 0 8px 24px rgba(27, 27, 27, 0.12);
			transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
		}

		.splash-enter:hover {
			transform: translateY(-2px);
			background: #2c2c2c;
			border-color: #2c2c2c;
			box-shadow: 0 16px 40px rgba(27, 27, 27, 0.15);
		}

		.splash-hint {
			margin: 1.75rem 0 0;
			font-size: 0.72rem;
			color: #2c2c2c;
			letter-spacing: 0.12em;
			text-transform: uppercase;
		}
	</style>
</Layout>
