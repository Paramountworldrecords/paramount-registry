---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Paramount World Records">
	<main class="min-h-screen flex flex-col items-center justify-center text-center px-4">
		<div class="border-4 border-[#D4AF37] p-12 max-w-4xl shadow-2xl">
			<h1 class="text-6xl font-bold text-[#D4AF37] mb-4 uppercase tracking-tighter">
				Paramount <span class="text-white">World Records</span>
			</h1>
			<div class="h-1 w-20 bg-[#D4AF37] mx-auto mb-8"></div>
			<p class="text-2xl text-white font-light italic mb-10">
				Official World Record Registry
			</p>
			<button class="bg-[#D4AF37] text-[#002147] px-10 py-4 font-bold uppercase hover:bg-white transition-all">
				Apply for Record
			</button>
		</div>
	</main>
</Layout>
