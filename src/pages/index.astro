---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Paramount World Records — Welcome" showChrome={false}>
	<main class="splash">
		<div class="splash-vignette" aria-hidden="true"></div>
		<div class="splash-inner">
			<p class="splash-tag">Elite Global Record Authority</p>
			<h1 class="splash-title">Paramount <span>World Records</span></h1>
			<p class="splash-line">Authorisation · Adjudication · Verification · Certification · Publishing</p>
			<a class="splash-enter" href="/home">Enter</a>
			<p class="splash-hint">Official registry — private entry</p>
		</div>
	</main>

	<style>
		/* Add /public/fonts/skylens-italic.woff2 for exact SKYLENS ITALIC rendering. */
		@font-face {
			font-family: "Skylens Italic";
			src: url("/fonts/skylens-italic.woff2") format("woff2");
			font-style: italic;
			font-weight: 400;
			font-display: swap;
		}

		.splash {
			min-height: 100vh;
			display: grid;
			place-items: center;
			padding: 2rem 1.25rem;
			position: relative;
			background:
				radial-gradient(ellipse 80% 50% at 50% -20%, rgba(196, 194, 188, 0.14), transparent 50%),
				radial-gradient(circle at 80% 80%, rgba(168, 189, 216, 0.08), transparent 45%),
				linear-gradient(180deg, #0a0a0a 0%, #030303 100%);
		}

		.splash-vignette {
			position: absolute;
			inset: 0;
			pointer-events: none;
			background: radial-gradient(ellipse 70% 60% at 50% 50%, transparent 0%, rgba(0, 0, 0, 0.55) 100%);
		}

		.splash-inner {
			position: relative;
			z-index: 1;
			text-align: center;
			max-width: 560px;
		}

		.splash-tag {
			margin: 0 0 0.5rem;
			font-size: 0.72rem;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			color: #a8bdd8;
		}

		.splash-title {
			margin: 0 0 0.75rem;
			font-size: clamp(1.85rem, 5.5vw, 2.75rem);
			font-family: "Skylens Italic", "Cormorant Garamond", Georgia, serif;
			font-style: italic;
			font-weight: 700;
			line-height: 1.08;
			text-transform: uppercase;
			letter-spacing: 0.02em;
			color: #e8e6e1;
			text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);
		}

		.splash-title span {
			display: block;
			color: #c4c2bc;
			background: linear-gradient(180deg, #ece9e4 0%, #9e9b95 100%);
			-webkit-background-clip: text;
			background-clip: text;
			-webkit-text-fill-color: transparent;
		}

		.splash-line {
			margin: 0 0 2rem;
			color: #9aa3b0;
			font-size: 0.88rem;
			letter-spacing: 0.06em;
		}

		.splash-enter {
			display: inline-block;
			padding: 1rem 2.75rem;
			text-decoration: none;
			border-radius: 3px;
			font-weight: 700;
			text-transform: uppercase;
			font-size: 0.88rem;
			letter-spacing: 0.2em;
			background: linear-gradient(145deg, #ece9e4 0%, #b0aca4 45%, #5e5c57 100%);
			color: #0a0a0a;
			box-shadow:
				0 4px 20px rgba(0, 0, 0, 0.35),
				inset 0 1px 0 rgba(255, 255, 255, 0.35);
			transition: transform 0.2s ease, box-shadow 0.2s ease;
		}

		.splash-enter:hover {
			transform: translateY(-2px);
			box-shadow:
				0 8px 28px rgba(0, 0, 0, 0.4),
				inset 0 1px 0 rgba(255, 255, 255, 0.4);
		}

		.splash-hint {
			margin: 1.5rem 0 0;
			font-size: 0.75rem;
			color: #5c6470;
			letter-spacing: 0.04em;
		}
	</style>
</Layout>
