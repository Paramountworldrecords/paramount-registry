---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Login">
	<main class="section">
		<div class="container panel about-panel" style="max-width: 480px; margin: 0 auto;" data-reveal>
			<h2>Login</h2>
			<p style="margin-top: -0.35rem; color: #a8b4c8; line-height: 1.6; font-size: 0.92rem;">
				Sign in with your <strong>username</strong> and <strong>password</strong>. Complete the captcha below.
			</p>

			<p id="loginMsg" class="form-msg" hidden></p>

			<form id="loginForm" class="apply-form" style="grid-template-columns: 1fr;" novalidate>
				<label class="full">
					Username
					<input type="text" name="username" required autocomplete="username" placeholder="Your username" />
				</label>
				<label class="full">
					Password
					<input type="password" name="password" required autocomplete="current-password" placeholder="Password" />
				</label>

				<div class="full captcha-block">
					<span class="records-label" style="margin-bottom: 0.35rem;">Security check</span>
					<div class="captcha-row">
						<label class="captcha-question" id="loginCaptchaLabel">Loading captcha…</label>
						<input type="number" name="captchaAnswer" id="loginCaptchaInput" required inputmode="numeric" placeholder="Answer" />
						<button type="button" class="btn-ghost-sm" id="loginCaptchaRefresh" aria-label="New captcha">New question</button>
					</div>
				</div>

				<div class="full" style="margin-top: 0.5rem;">
					<button type="submit" class="btn btn-primary">Login</button>
					<a href="/register" style="margin-left: 0.75rem; font-size: 0.9rem;">New user? Register</a>
				</div>
			</form>
		</div>
	</main>

	<script>
		(function () {
			var cap = { a: 0, b: 0, answer: 0 };

			function renderCaptcha() {
				if (!window.ParamountAuth) return;
				cap = window.ParamountAuth.newMathCaptcha();
				var el = document.getElementById("loginCaptchaLabel");
				var input = document.getElementById("loginCaptchaInput");
				if (el) el.textContent = "What is " + cap.a + " + " + cap.b + "?";
				if (input) input.value = "";
			}

			function showMsg(text, ok) {
				var m = document.getElementById("loginMsg");
				if (!m) return;
				m.textContent = text;
				m.hidden = !text;
				m.style.color = ok ? "#a8e6cf" : "#ffb4b4";
			}

			document.getElementById("loginCaptchaRefresh")?.addEventListener("click", renderCaptcha);

			document.getElementById("loginForm")?.addEventListener("submit", async function (e) {
				e.preventDefault();
				showMsg("", true);
				var fd = new FormData(e.target);
				var username = (fd.get("username") || "").trim();
				var password = fd.get("password");
				var captchaAns = parseInt(String(fd.get("captchaAnswer") || ""), 10);

				if (!window.ParamountAuth) {
					showMsg("Auth script failed to load. Refresh the page.", false);
					return;
				}
				if (Number.isNaN(captchaAns) || captchaAns !== cap.answer) {
					showMsg("Captcha is incorrect. Try again.", false);
					renderCaptcha();
					return;
				}

				try {
					var user = await window.ParamountAuth.verifyLogin(username, password);
					window.ParamountAuth.setSession(user);
					showMsg("Success. Redirecting…", true);
					window.ParamountAuth.updateNav();
					setTimeout(function () {
						window.location.href = "/home";
					}, 400);
				} catch (err) {
					showMsg(err.message || "Login failed.", false);
					renderCaptcha();
				}
			});

			renderCaptcha();
		})();
	</script>

	<style>
		.form-msg {
			margin: 1rem 0 0;
			padding: 0.65rem 0.75rem;
			border-radius:2px;
			background: rgba(0,0,0,.25);
			font-size: 0.9rem;
		}
		.captcha-block { margin-top: 0.25rem; }
		.captcha-row {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.65rem;
		}
		.captcha-question {
			flex: 1;
			min-width: 180px;
			margin: 0;
			color: #d2dae6;
			font-size: 0.95rem;
		}
		.captcha-row input[type="number"] { width: 100px; }
		.btn-ghost-sm {
			cursor: pointer;
			border: 1px solid rgba(196, 194, 188, 0.5);
			background: transparent;
			color: #e8e6e1;
			padding: 0.5rem 0.75rem;
			font-size: 0.78rem;
			border-radius: 2px;
			font-family: inherit;
		}
		.btn-ghost-sm:hover { background: rgba(255,255,255,.08); }
		.records-label {
			display: block;
			font-size: 0.82rem;
			text-transform: uppercase;
			letter-spacing: 0.06em;
			color: #a8bdd8;
		}
	</style>
</Layout>
