---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Login">
	<main class="section">
		<div class="container panel about-panel" style="max-width: 480px; margin: 0 auto;" data-reveal>
			<h2>Login</h2>
			<p style="margin-top: -0.35rem; color: #a8b4c8; line-height: 1.6; font-size: 0.92rem;">
				Sign in with your <strong>username</strong> and <strong>password</strong>. Complete the captcha below.
			</p>

			<p id="loginMsg" class="form-msg" hidden></p>

			<form id="loginForm" class="apply-form" style="grid-template-columns: 1fr;" novalidate>
				<label class="full">
					Username
					<input type="text" name="username" required autocomplete="username" placeholder="Your username" />
				</label>
				<label class="full">
					Password
					<input type="password" name="password" required autocomplete="current-password" placeholder="Password" />
				</label>

				<div class="full captcha-block">
					<span class="records-label" style="margin-bottom: 0.35rem;">Security check</span>
					<div class="captcha-row">
						<label class="captcha-question" id="loginCaptchaLabel">Loading captcha…</label>
						<input type="number" name="captchaAnswer" id="loginCaptchaInput" required inputmode="numeric" placeholder="Answer" />
						<button type="button" class="btn-ghost-sm" id="loginCaptchaRefresh" aria-label="New captcha">New question</button>
					</div>
				</div>

				<div class="full" style="margin-top: 0.5rem;">
					<button type="submit" class="btn btn-primary">Login</button>
					<a href="/register" style="margin-left: 0.75rem; font-size: 0.9rem;">New user? Register</a>
				</div>
			</form>
		</div>
	</main>

	<script>
		import { getSupabase } from "../lib/supabaseBrowser";

		function newMathCaptcha() {
			const a = Math.floor(Math.random() * 9) + 1;
			const b = Math.floor(Math.random() * 9) + 1;
			return { a, b, answer: a + b };
		}

		let cap = newMathCaptcha();

		function renderCaptcha() {
			cap = newMathCaptcha();
			const el = document.getElementById("loginCaptchaLabel");
			const input = document.getElementById("loginCaptchaInput");
			if (el) el.textContent = "What is " + cap.a + " + " + cap.b + "?";
			if (input) input.value = "";
		}

		function showMsg(text, ok) {
			const m = document.getElementById("loginMsg");
			if (!m) return;
			m.textContent = text;
			m.hidden = !text;
			m.style.color = ok ? "#a8e6cf" : "#ffb4b4";
		}

		document.getElementById("loginCaptchaRefresh")?.addEventListener("click", renderCaptcha);

		document.getElementById("loginForm")?.addEventListener("submit", async (e) => {
			e.preventDefault();
			showMsg("", true);
			const form = e.target;
			if (!(form instanceof HTMLFormElement)) return;
			const fd = new FormData(form);
			const username = (fd.get("username") || "").toString().trim();
			const password = (fd.get("password") || "").toString();
			const captchaAns = parseInt(String(fd.get("captchaAnswer") || ""), 10);

			const supabase = getSupabase();
			if (!supabase) {
				showMsg(
					"Supabase is not configured. Add PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY in Vercel (or .env) and redeploy.",
					false
				);
				return;
			}
			if (Number.isNaN(captchaAns) || captchaAns !== cap.answer) {
				showMsg("Captcha is incorrect. Try again.", false);
				renderCaptcha();
				return;
			}
			if (!username || !password) {
				showMsg("Enter username and password.", false);
				return;
			}

			const { data: email, error: rpcErr } = await supabase.rpc("login_email_for_username", {
				p_username: username,
			});
			if (rpcErr) {
				showMsg(rpcErr.message, false);
				renderCaptcha();
				return;
			}
			if (!email || String(email).trim() === "") {
				showMsg("Invalid username or password.", false);
				renderCaptcha();
				return;
			}

			const { error: signErr } = await supabase.auth.signInWithPassword({
				email: String(email).trim(),
				password,
			});
			if (signErr) {
				showMsg("Invalid username or password.", false);
				renderCaptcha();
				return;
			}

			showMsg("Success. Redirecting…", true);
			setTimeout(() => {
				window.location.href = "/dashboard";
			}, 400);
		});

		renderCaptcha();
	</script>

	<style>
		.form-msg {
			margin: 1rem 0 0;
			padding: 0.65rem 0.75rem;
			border-radius: var(--radius-card, 16px);
			background: var(--surface-muted, #f8fafc);
			border: 1px solid var(--border-subtle, #e2e8f0);
			font-size: 0.9rem;
			color: var(--text-primary, #0f172a);
		}
		.captcha-block { margin-top: 0.25rem; }
		.captcha-row {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.65rem;
		}
		.captcha-question {
			flex: 1;
			min-width: 180px;
			margin: 0;
			color: var(--text-secondary, #475569);
			font-size: 0.95rem;
		}
		.captcha-row input[type="number"] { width: 100px; }
		.btn-ghost-sm {
			cursor: pointer;
			border: 1px solid var(--border-subtle, #e2e8f0);
			background: var(--surface-card, #fff);
			color: var(--text-primary, #0f172a);
			padding: 0.5rem 0.75rem;
			font-size: 0.78rem;
			border-radius: var(--radius-card, 16px);
			font-family: inherit;
		}
		.btn-ghost-sm:hover { background: var(--accent-soft, rgba(79, 70, 229, 0.1)); border-color: var(--accent, #4f46e5); }
		.records-label {
			display: block;
			font-size: 0.82rem;
			text-transform: uppercase;
			letter-spacing: 0.06em;
			color: var(--text-muted, #94a3b8);
		}
	</style>
</Layout>
