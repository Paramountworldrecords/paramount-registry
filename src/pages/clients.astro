---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Our Esteemed Clients">
	<main class="section">
		<div class="container panel" data-reveal>
			<h2>Our Esteemed Clients</h2>
			<p style="margin-top: -0.4rem; color: #d8e0ef; line-height: 1.6;">
				Trusted by corporate groups, schools, universities, NGOs and cultural institutions for high-credibility certification workflows.
			</p>

			<div class="grid three" style="margin-top: 1.2rem;">
				<div class="panel" style="background: transparent; border: 1px solid rgba(212,175,55,0.25); min-height: 120px; display:flex; align-items:center; justify-content:center;" data-reveal>Schools & Colleges</div>
				<div class="panel" style="background: transparent; border: 1px solid rgba(212,175,55,0.25); min-height: 120px; display:flex; align-items:center; justify-content:center;" data-reveal>NGOs & Cultural Groups</div>
				<div class="panel" style="background: transparent; border: 1px solid rgba(212,175,55,0.25); min-height: 120px; display:flex; align-items:center; justify-content:center;" data-reveal>Corporate Partners</div>
			</div>
		</div>
	</main>
</Layout>

