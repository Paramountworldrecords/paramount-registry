---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Departments & Verification Process">
	<main class="section">
		<div class="container panel about-panel" data-reveal>
			<h2>Our Departments & Verification Process</h2>
			<p style="margin-top: -0.4rem; color: var(--text-secondary); line-height: 1.6; max-width: 900px;">
				Our workflow ensures authenticity, transparency and premium certification—from application intake to final publication.
			</p>

			<div class="grid two" style="margin-top: 1.2rem;">
				<section class="panel" style="background: transparent; border: 1px solid rgba(196,194,188,0.3);" data-reveal>
					<h3 style="margin-bottom: 0.6rem; color: #c4c2bc;">Core Departments</h3>
					<ul class="suggestions" style="margin-top: 0;">
						<li>Application Screening & Eligibility</li>
						<li>Event Adjudication & Compliance</li>
						<li>Evidence Audit & Verification</li>
						<li>Certification & Publication</li>
						<li>Press, Partnerships & Client Relations</li>
					</ul>
				</section>

				<section class="panel" style="background: transparent; border: 1px solid rgba(196,194,188,0.3);" data-reveal>
					<h3 style="margin-bottom: 0.6rem; color: #c4c2bc;">Verification Process</h3>
					<ol class="steps" style="margin-top: 0; padding-left: 1.2rem;">
						<li>Application submission and initial suitability review</li>
						<li>Rulebook issue and attempt protocol confirmation</li>
						<li>Live/recorded evidence collection and witness checks</li>
						<li>Expert adjudication and authenticity audit</li>
						<li>Final certification, registry listing and media release</li>
					</ol>
				</section>
			</div>
		</div>
	</main>
</Layout>

