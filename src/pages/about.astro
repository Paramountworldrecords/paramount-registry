---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us">
	<main class="section">
		<div class="container panel about-panel" data-reveal>
			<h2>About Us</h2>
			<p>
				Paramount World Records is an independent Pvt. Ltd. company headquartered in Mumbai. We
				operate with branches in Chennai, Coimbatore and Kancheepuram—and we are continuously expanding.
			</p>
			<p>
				Our registry is built to support authenticity and excellence through transparent validation,
				expert verification, and trusted certification—so that every extraordinary effort gets global recognition.
			</p>
		</div>
	</main>
</Layout>

