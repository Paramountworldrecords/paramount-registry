---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Vision & Mission">
	<main class="section">
		<div class="container panel about-panel" data-reveal>
			<h2>Vision & Mission</h2>
			<div class="grid two" style="margin-top: 1.2rem;">
				<section class="panel" style="background: transparent; border: 1px solid rgba(196,194,188,0.3);" data-reveal>
					<h3 style="color: #c4c2bc;">Our Vision</h3>
					<p style="margin: 0; color: #e9f0ff; line-height: 1.7;">
						To become the most respected elite platform for celebrating extraordinary human achievement with authenticity and dignity.
					</p>
				</section>

				<section class="panel" style="background: transparent; border: 1px solid rgba(196,194,188,0.3);" data-reveal>
					<h3 style="color: #c4c2bc;">Our Mission</h3>
					<p style="margin: 0; color: #e9f0ff; line-height: 1.7;">
						To identify, verify, certify and publish world records through clear protocols, expert adjudication,
						and a premium candidate experience.
					</p>
				</section>
			</div>
		</div>
	</main>
</Layout>

