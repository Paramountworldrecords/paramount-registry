---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Press & Media Release">
	<main class="section">
		<div class="container panel about-panel" data-reveal>
			<h2>Press & Media Release</h2>
			<p style="margin-top: -0.4rem; color: #d8e0ef; line-height: 1.6; max-width: 900px;">
				Official announcements, event coverage, and certification releases will appear here.
				For media enquiries, email us at
				<a href="mailto:apply@paramountworldrecords.com">apply@paramountworldrecords.com</a>.
			</p>
			<div class="grid two" style="margin-top: 1.2rem;">
				<div class="panel" style="background: transparent; border: 1px solid rgba(212,175,55,0.25);" data-reveal>Latest Release Placeholder</div>
				<div class="panel" style="background: transparent; border: 1px solid rgba(212,175,55,0.25);" data-reveal>Media Kit Placeholder</div>
			</div>
		</div>
	</main>
</Layout>

