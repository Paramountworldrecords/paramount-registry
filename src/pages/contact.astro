---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us">
	<main class="section">
		<div class="container panel" data-reveal>
			<h2>Contact Us</h2>
			<div class="grid two" style="margin-top: 1.2rem;">
				<section class="panel" style="background: transparent; border: 1px solid rgba(196,194,188,0.3);" data-reveal>
					<h3 style="color:#c4c2bc;">Phone & WhatsApp</h3>
					<p style="margin: 0; color:#e9f0ff; line-height: 1.7;"><strong>+91 7550015677</strong></p>
					<p style="margin: 0.2rem 0 0; color:#e9f0ff; line-height: 1.7;"><strong>+91 9987814980</strong></p>
				</section>
				<section class="panel" style="background: transparent; border: 1px solid rgba(196,194,188,0.3);" data-reveal>
					<h3 style="color:#c4c2bc;">Email</h3>
					<p style="margin: 0; color:#e9f0ff; line-height: 1.7;">
						<a href="mailto:admin@paramountworldrecords.com">admin@paramountworldrecords.com</a>
					</p>
				</section>
			</div>
			<section style="margin-top: 1.2rem;" data-reveal>
				<h3 style="color:#c4c2bc;">Headquarters & Active Branches</h3>
				<p style="margin: 0; color:#e9f0ff; line-height: 1.7;">
					Mumbai HQ. Branches in Chennai, Coimbatore and Kancheepuram (and counting).
				</p>
			</section>
		</div>
	</main>
</Layout>

