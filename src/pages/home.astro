---
import Layout from "../layouts/Layout.astro";
import AuthorityProcess from "../components/AuthorityProcess.astro";
---
<Layout title="Paramount World Records — Home">
	<main id="home" class="home-landing">
		<section class="hero section">
			<div class="container hero-card" data-reveal>
				<p class="tag">Elite Global Record Authority</p>
				<h1>Paramount <span>World Records</span></h1>
				<p class="lead">
					Independent registry for record authorisation and certification—governed by published rules,
					evidence-led review, and adjudication. Publication follows verified outcomes, not headlines.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="/apply">Apply For A Record</a>
					<a class="btn btn-ghost" href="/records">Search Record Suggestions</a>
				</div>
			</div>
		</section>
		<AuthorityProcess />
	</main>

	<style>
		.home-landing {
			display: flex;
			flex-direction: column;
			min-height: calc(100vh - 12rem);
		}

		.home-landing .hero {
			flex: 1;
			padding-top: clamp(2rem, 5vh, 3.25rem);
			padding-bottom: clamp(1.25rem, 3vh, 2rem);
			display: grid;
			align-items: center;
			align-content: center;
			min-height: min(72vh, 720px);
		}

		.hero-actions {
			display: flex;
			justify-content: center;
			flex-wrap: wrap;
			gap: 0.8rem;
			margin-top: 1.4rem;
		}
	</style>
</Layout>
