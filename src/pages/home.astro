---
import Layout from "../layouts/Layout.astro";
import AuthorityProcess from "../components/AuthorityProcess.astro";

const serviceCards = [
	{
		title: "Application intake",
		text: "Structured screening and category matching before the attempt cycle begins.",
		href: "/apply",
	},
	{
		title: "Adjudication protocol",
		text: "Defined evidence framework, witness guidance, and transparent review workflows.",
		href: "/departments",
	},
	{
		title: "Publication support",
		text: "Qualified achievements are prepared for registry publication and media-ready release.",
		href: "/press-media",
	},
];
---

<Layout title="Paramount World Records — Home">
	<main id="home" class="home-redesign">
		<section class="hero-video section section--flush">
			<div class="hero-video-bg" aria-hidden="true">
				<!-- Replace this file with your final hero video: /public/media/home-hero.mp4 -->
				<video autoplay muted loop playsinline poster="/images/logo.png">
					<source src="/media/home-hero.mp4" type="video/mp4" />
				</video>
			</div>
			<div class="hero-overlay" aria-hidden="true"></div>

			<div class="container hero-content" data-reveal>
				<p class="hero-kicker">Independent Record Authority</p>
				<h1>Recognize Extraordinary Performance With Verified Standards</h1>
				<p class="hero-text">
					From application to certification, we run a transparent process based on written rules,
					adjudication discipline, and evidence-led decisions.
				</p>
				<div class="hero-cta-row">
					<a class="btn btn-primary" href="/apply">Apply For A Record</a>
					<a class="btn btn-ghost" href="/records">Explore Record Suggestions</a>
				</div>
				<ul class="hero-metrics" aria-label="Key highlights">
					<li><strong>200+</strong><span>Records reviewed</span></li>
					<li><strong>5-stage</strong><span>Verification cycle</span></li>
					<li><strong>Pan-India</strong><span>Operations and support</span></li>
				</ul>
			</div>
		</section>

		<section class="section home-services">
			<div class="container" data-reveal>
				<p class="tag">Core capabilities</p>
				<h2>Built for credibility, speed, and traceability</h2>
				<p class="home-services-intro">
					Your applicant journey stays structured from day one, with clearer expectations and cleaner outcomes.
				</p>
				<div class="service-grid">
					{
						serviceCards.map((card) => (
							<article class="service-card panel">
								<h3>{card.title}</h3>
								<p>{card.text}</p>
								<a href={card.href}>Learn more</a>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<AuthorityProcess />
	</main>

	<style>
		.home-redesign {
			display: flex;
			flex-direction: column;
		}

		.hero-video.section.section--flush {
			padding-top: 0;
			padding-bottom: 0;
		}

		.hero-video {
			position: relative;
			padding-top: clamp(8rem, 14vh, 11rem);
			padding-bottom: clamp(6rem, 12vh, 9rem);
			min-height: min(88vh, 860px);
			overflow: hidden;
		}

		.hero-video-bg,
		.hero-video-bg video {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
		}

		.hero-video-bg video {
			object-fit: cover;
			filter: saturate(0.55) brightness(1.05) contrast(0.95);
			animation: kenBurns 26s ease-in-out infinite alternate;
		}

		.hero-overlay {
			position: absolute;
			inset: 0;
			background:
				linear-gradient(105deg, rgba(228, 228, 222, 0.94) 0%, rgba(228, 228, 222, 0.78) 48%, rgba(228, 228, 222, 0.88) 100%),
				radial-gradient(circle at 85% 40%, rgba(196, 197, 186, 0.35), transparent 42%);
		}

		.hero-video::after {
			content: "";
			position: absolute;
			left: 0;
			right: 0;
			bottom: 0;
			height: 32%;
			background: linear-gradient(180deg, rgba(228, 228, 222, 0) 0%, rgba(228, 228, 222, 1) 100%);
			pointer-events: none;
		}

		.hero-content {
			position: relative;
			z-index: 1;
			max-width: 38rem;
		}

		.hero-kicker {
			display: inline-block;
			margin: 0;
			padding: 0.35rem 0.75rem;
			font-size: 0.65rem;
			letter-spacing: 0.2em;
			text-transform: uppercase;
			border: 1px solid var(--border-sage);
			border-radius: 2px;
			color: var(--text-secondary);
			background: rgba(255, 255, 255, 0.45);
		}

		.hero-content h1 {
			margin-top: 1.35rem;
			font-size: clamp(2.1rem, 5vw, 3.65rem);
			line-height: 1.06;
			text-transform: none;
			letter-spacing: -0.03em;
			color: var(--text-primary);
			background: none;
			-webkit-background-clip: unset;
			background-clip: unset;
			max-width: 18ch;
		}

		.hero-text {
			margin: 1.35rem 0 0;
			max-width: 36rem;
			font-size: clamp(0.98rem, 1.4vw, 1.06rem);
			line-height: 1.85;
			color: var(--text-secondary);
		}

		.hero-cta-row {
			display: flex;
			flex-wrap: wrap;
			gap: 1rem;
			margin-top: 2.25rem;
		}

		.hero-metrics {
			list-style: none;
			margin: 2.5rem 0 0;
			padding: 0;
			display: flex;
			gap: 1rem;
			flex-wrap: wrap;
		}

		.hero-metrics li {
			display: grid;
			gap: 0.2rem;
			padding: 1rem 1.15rem;
			min-width: 124px;
			border-radius: 2px;
			border: 1px solid var(--border-sage);
			background: linear-gradient(165deg, var(--bg-sage) 0%, var(--bg-sage-deep) 100%);
			box-shadow: var(--shadow-soft-sm);
		}

		.hero-metrics strong {
			font-size: 1.05rem;
			font-family: var(--font-display);
			font-weight: 600;
			color: var(--text-primary);
		}

		.hero-metrics span {
			font-size: 0.72rem;
			letter-spacing: 0.06em;
			text-transform: uppercase;
			color: var(--text-secondary);
		}

		.home-services {
			padding-top: clamp(2rem, 5vw, 3rem);
		}

		.home-services h2 {
			font-size: clamp(1.65rem, 3.3vw, 2.35rem);
			max-width: 760px;
			text-transform: none;
			line-height: 1.2;
		}

		.home-services-intro {
			max-width: 650px;
			margin: 1.25rem 0 2.5rem;
			font-size: 1.05rem;
			line-height: 1.8;
			color: var(--text-secondary);
		}

		.service-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
			gap: 1.75rem;
		}

		.service-card {
			position: relative;
			overflow: hidden;
			border-radius: 2px;
			min-height: 100%;
		}

		.service-card h3 {
			margin: 0;
			font-size: 1.08rem;
			font-family: var(--font-display);
			font-weight: 600;
			color: var(--text-primary);
		}

		.service-card p {
			margin: 0.85rem 0 1.5rem;
			font-size: 0.92rem;
			line-height: 1.75;
			color: var(--text-secondary);
		}

		.service-card a {
			font-size: 0.72rem;
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.14em;
			color: var(--text-primary);
			border-bottom: 1px solid var(--border-sage);
			padding-bottom: 0.15rem;
		}

		.service-card a:hover {
			opacity: 1;
			border-bottom-color: var(--text-primary);
		}

		@keyframes kenBurns {
			0% {
				transform: scale(1);
			}
			100% {
				transform: scale(1.06);
			}
		}

		@media (max-width: 680px) {
			.hero-video {
				min-height: 74vh;
			}

			.hero-content h1 {
				line-height: 1.05;
			}
		}
	</style>
</Layout>
