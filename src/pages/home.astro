---
import Layout from "../layouts/Layout.astro";
import AuthorityProcess from "../components/AuthorityProcess.astro";

const serviceCards = [
	{
		title: "Application intake",
		text: "Structured screening and category matching before the attempt cycle begins.",
		href: "/apply",
	},
	{
		title: "Adjudication protocol",
		text: "Defined evidence framework, witness guidance, and transparent review workflows.",
		href: "/departments",
	},
	{
		title: "Publication support",
		text: "Qualified achievements are prepared for registry publication and media-ready release.",
		href: "/press-media",
	},
];
---

<Layout title="Paramount World Records — Home">
	<main id="home" class="home-redesign">
		<section class="hero-video section section--flush">
			<div class="hero-video-bg" aria-hidden="true">
				<!-- Replace this file with your final hero video: /public/media/home-hero.mp4 -->
				<video autoplay muted loop playsinline poster="/images/logo.png">
					<source src="/media/home-hero.mp4" type="video/mp4" />
				</video>
			</div>
			<div class="hero-overlay" aria-hidden="true"></div>

			<div class="container hero-content" data-reveal>
				<div class="hero-mist" aria-hidden="true"></div>
				<p class="hero-kicker">Independent record authority</p>
				<h1>
					Recognize extraordinary performance with verified standards<span class="stoplight" aria-hidden="true">.</span>
				</h1>
				<p class="hero-text">
					From application to certification, we run a transparent process based on written rules,
					adjudication discipline, and evidence-led decisions.
				</p>
				<div class="hero-cta-row">
					<a class="btn btn-primary" href="/apply">Apply For A Record</a>
					<a class="btn btn-ghost" href="/records">Explore Record Suggestions</a>
				</div>
				<ul class="hero-metrics" aria-label="Key highlights">
					<li><strong>200+</strong><span>Records reviewed</span></li>
					<li><strong>5-stage</strong><span>Verification cycle</span></li>
					<li><strong>Pan-India</strong><span>Operations and support</span></li>
				</ul>
			</div>
		</section>

		<section class="section home-services">
			<div class="container" data-reveal>
				<p class="tag">Core capabilities</p>
				<h2>Built for credibility speed and traceability<span class="stoplight" aria-hidden="true">.</span></h2>
				<p class="home-services-intro">
					Your applicant journey stays structured from day one, with clearer expectations and cleaner outcomes.
				</p>
				<div class="service-grid">
					{
						serviceCards.map((card) => (
							<article class="service-card panel">
								<h3>{card.title}</h3>
								<p>{card.text}</p>
								<a href={card.href}>Learn more</a>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<AuthorityProcess />
	</main>

	<style>
		.home-redesign {
			display: flex;
			flex-direction: column;
		}

		.hero-video.section.section--flush {
			padding-top: 0;
			padding-bottom: 0;
		}

		.hero-video {
			position: relative;
			padding-top: clamp(9rem, 16vh, 12rem);
			padding-bottom: clamp(7rem, 14vh, 10rem);
			min-height: min(92vh, 920px);
			overflow: hidden;
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.hero-video-bg,
		.hero-video-bg video {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
		}

		.hero-video-bg video {
			object-fit: cover;
			filter: saturate(0.35) brightness(0.35) contrast(1.05);
			animation: kenBurns 28s ease-in-out infinite alternate;
		}

		.hero-overlay {
			position: absolute;
			inset: 0;
			background:
				linear-gradient(180deg, rgba(8, 8, 8, 0.5) 0%, rgba(8, 8, 8, 0.88) 100%),
				radial-gradient(circle at 50% 35%, rgba(0, 201, 167, 0.12) 0%, transparent 55%);
		}

		.hero-video::after {
			content: "";
			position: absolute;
			left: 0;
			right: 0;
			bottom: 0;
			height: 28%;
			background: linear-gradient(180deg, transparent 0%, var(--bg-noir, #080808) 100%);
			pointer-events: none;
		}

		.hero-content {
			position: relative;
			z-index: 1;
			width: 100%;
			max-width: min(1040px, 94vw);
			margin: 0 auto;
			text-align: center;
		}

		.hero-mist {
			position: absolute;
			left: 50%;
			top: 42%;
			transform: translate(-50%, -50%);
			width: min(140vw, 920px);
			height: min(90vw, 520px);
			background: radial-gradient(circle, rgba(0, 201, 167, 0.15) 0%, transparent 70%);
			pointer-events: none;
			z-index: 0;
		}

		.hero-content .hero-kicker,
		.hero-content h1,
		.hero-content .hero-text,
		.hero-content .hero-cta-row,
		.hero-content .hero-metrics {
			position: relative;
			z-index: 1;
		}

		.hero-kicker {
			display: inline-block;
			margin: 0;
			padding: 0.4rem 1rem;
			font-family: var(--font-label, "Montserrat", sans-serif);
			font-size: 0.62rem;
			font-weight: 300;
			letter-spacing: 0.2em;
			text-transform: uppercase;
			border: 1px solid var(--border-noir, #1f1f1f);
			border-radius: 24px;
			color: rgba(255, 255, 255, 0.65);
			background: rgba(18, 18, 18, 0.65);
		}

		.hero-content h1 {
			margin: 1.75rem auto 0;
			font-family: var(--font-hero, "Anton", sans-serif);
			font-size: clamp(2.4rem, 8.5vw, 5.75rem);
			font-weight: 400;
			line-height: 0.95;
			text-transform: uppercase;
			letter-spacing: -0.045em;
			color: #ffffff;
			max-width: 16ch;
			background: none;
			-webkit-background-clip: unset;
			background-clip: unset;
		}

		.hero-text {
			margin: 1.75rem auto 0;
			max-width: 36rem;
			font-size: clamp(0.95rem, 1.5vw, 1.08rem);
			line-height: 1.8;
			color: rgba(255, 255, 255, 0.72);
		}

		.hero-cta-row {
			display: flex;
			flex-wrap: wrap;
			gap: 1rem;
			margin-top: 2.5rem;
			justify-content: center;
		}

		.hero-metrics {
			list-style: none;
			margin: 3rem auto 0;
			padding: 0;
			display: flex;
			gap: 1rem;
			flex-wrap: wrap;
			justify-content: center;
		}

		.hero-metrics li {
			display: grid;
			gap: 0.25rem;
			padding: 1.1rem 1.35rem;
			min-width: 130px;
			border-radius: 24px;
			border: 1px solid var(--border-noir, #1f1f1f);
			background: var(--surface-noir, #121212);
			box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
		}

		.hero-metrics strong {
			font-size: 1.1rem;
			font-family: var(--font-hero, "Anton", sans-serif);
			font-weight: 400;
			letter-spacing: -0.02em;
			color: #ffffff;
		}

		.hero-metrics span {
			font-family: var(--font-label, "Montserrat", sans-serif);
			font-size: 0.62rem;
			font-weight: 300;
			letter-spacing: 0.2em;
			text-transform: uppercase;
			color: rgba(255, 255, 255, 0.55);
		}

		.home-services {
			padding-top: clamp(1rem, 4vw, 2rem);
		}

		.home-services h2 {
			max-width: 20ch;
			margin-left: auto;
			margin-right: auto;
			text-align: center;
			line-height: 0.98;
		}

		.home-services .tag {
			text-align: center;
		}

		.home-services-intro {
			max-width: 36rem;
			margin: 1.5rem auto 2.75rem;
			font-size: 1rem;
			line-height: 1.8;
			text-align: center;
			color: rgba(255, 255, 255, 0.72);
		}

		.service-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
			gap: 1.5rem;
		}

		.service-card {
			position: relative;
			overflow: hidden;
			border-radius: 24px;
			min-height: 100%;
		}

		.service-card h3 {
			margin: 0;
			font-size: 0.72rem;
			font-family: var(--font-label, "Montserrat", sans-serif);
			font-weight: 500;
			letter-spacing: 0.2em;
			text-transform: uppercase;
			color: #ffffff;
		}

		.service-card p {
			margin: 1rem 0 1.5rem;
			font-size: 0.92rem;
			line-height: 1.7;
			color: rgba(255, 255, 255, 0.7);
		}

		.service-card a {
			font-family: var(--font-label, "Montserrat", sans-serif);
			font-size: 0.62rem;
			font-weight: 500;
			text-transform: uppercase;
			letter-spacing: 0.2em;
			color: #ffffff;
			border-bottom: 1px solid rgba(255, 255, 255, 0.35);
			padding-bottom: 0.2rem;
		}

		.service-card a:hover {
			opacity: 1;
			border-bottom-color: #ff0000;
		}

		@keyframes kenBurns {
			0% {
				transform: scale(1);
			}
			100% {
				transform: scale(1.07);
			}
		}

		@media (max-width: 680px) {
			.hero-video {
				min-height: 78vh;
			}

			.hero-content h1 {
				max-width: none;
			}
		}
	</style>
</Layout>
