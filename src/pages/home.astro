---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Paramount World Records — Home">
	<main id="home" class="home-landing">
		<section class="hero section">
			<div class="container hero-card" data-reveal>
				<p class="tag">Elite Global Record Authority</p>
				<h1>Paramount <span>World Records</span></h1>
				<p class="lead">
					Independent record authorisation, adjudication, verification, certification and publishing.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="/apply">Apply For A Record</a>
					<a class="btn btn-ghost" href="/records">Search Record Suggestions</a>
				</div>
			</div>
		</section>
	</main>

	<style>
		/* Single-view home: hero only (other sections live on their own routes: /about, /apply, …) */
		.home-landing {
			min-height: calc(100vh - 14rem);
			display: flex;
			flex-direction: column;
		}

		.home-landing .hero {
			flex: 1;
			padding-top: clamp(2rem, 6vh, 3.5rem);
			padding-bottom: clamp(2rem, 6vh, 3rem);
			display: grid;
			align-items: center;
			align-content: center;
		}

		.hero-actions {
			display: flex;
			justify-content: center;
			flex-wrap: wrap;
			gap: 0.8rem;
			margin-top: 1.4rem;
		}
	</style>
</Layout>
