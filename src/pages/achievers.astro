---
import Layout from '../layouts/Layout.astro';
---

<Layout title="World Record Achievers">
	<main class="section">
		<div class="container panel" data-reveal>
			<h2>World Record Achievers</h2>
			<p style="margin-top: -0.4rem; color: var(--text-secondary); line-height: 1.6;">
				Highlights of certified record achievements. Replace placeholder entries with your verified registry records as you publish.
			</p>

			<div class="grid three" style="margin-top: 1.2rem;">
				<article class="panel" style="background: transparent; border: 1px solid rgba(196,194,188,0.3);" data-reveal>
					<h3 style="color:#c4c2bc; margin-bottom: 0.45rem;">Longest Classical Dance Marathon</h3>
					<p style="margin: 0; color:var(--text-secondary); line-height: 1.6;">Mumbai, India - Certified by Paramount review board.</p>
				</article>
				<article class="panel" style="background: transparent; border: 1px solid rgba(196,194,188,0.3);" data-reveal>
					<h3 style="color:#c4c2bc; margin-bottom: 0.45rem;">Largest STEM Student Workshop</h3>
					<p style="margin: 0; color:var(--text-secondary); line-height: 1.6;">Chennai, India - Multi-city participant audit completed.</p>
				</article>
				<article class="panel" style="background: transparent; border: 1px solid rgba(196,194,188,0.3);" data-reveal>
					<h3 style="color:#c4c2bc; margin-bottom: 0.45rem;">Fastest Community Plantation Drive</h3>
					<p style="margin: 0; color:var(--text-secondary); line-height: 1.6;">Coimbatore, India - Adjudicated and archived for publication.</p>
				</article>
			</div>
		</div>
	</main>
</Layout>

