---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Work With Us">
	<main class="section">
		<div class="container panel about-panel" data-reveal>
			<h2>Work With Us</h2>
			<p style="margin-top: -0.4rem; color: #d8e0ef; line-height: 1.6; max-width: 900px;">
				Partner with us as adjudicators, event associates, city coordinators, and media collaborators across Mumbai, Chennai, Coimbatore and Kancheepuram.
			</p>
			<div class="grid two" style="margin-top: 1.2rem;">
				<div class="panel" style="background: transparent; border: 1px solid rgba(212,175,55,0.25);" data-reveal>
					<h3 style="color:#d4af37;">City Coordination</h3>
					<p style="margin: 0; color:#e9f0ff; line-height: 1.7;">Local event scheduling, evidence collection coordination, and reporting.</p>
				</div>
				<div class="panel" style="background: transparent; border: 1px solid rgba(212,175,55,0.25);" data-reveal>
					<h3 style="color:#d4af37;">Adjudication & Verification</h3>
					<p style="margin: 0; color:#e9f0ff; line-height: 1.7;">Expert review, authenticity checks, and certification readiness.</p>
				</div>
			</div>
			<p style="margin-top: 1.2rem; color:#d8e0ef; line-height: 1.6;">
				Email us at <a href="mailto:apply@paramountworldrecords.com">apply@paramountworldrecords.com</a>
				with your profile and region of interest.
			</p>
		</div>
	</main>
</Layout>

