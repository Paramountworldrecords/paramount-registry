---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Gallery">
	<main class="section">
		<div class="container panel about-panel" data-reveal>
			<h2>Gallery</h2>
			<p style="margin-top: -0.4rem; color: #d8e0ef; line-height: 1.6;">
				Inspiring record-attempt visuals and achievement moments.
			</p>

			<div class="grid three" style="margin-top: 1.2rem;">
				<figure class="panel" style="padding: 0.4rem; background: rgba(11,27,53,0.35);" data-reveal><img src="/images/gallery/gallery-1.png" alt="Inspiring gallery image 1" style="width:100%; height:210px; object-fit:cover; border-radius:2px;" /></figure>
				<figure class="panel" style="padding: 0.4rem; background: rgba(11,27,53,0.35);" data-reveal><img src="/images/gallery/gallery-2.png" alt="Inspiring gallery image 2" style="width:100%; height:210px; object-fit:cover; border-radius:2px;" /></figure>
				<figure class="panel" style="padding: 0.4rem; background: rgba(11,27,53,0.35);" data-reveal><img src="/images/gallery/gallery-3.png" alt="Inspiring gallery image 3" style="width:100%; height:210px; object-fit:cover; border-radius:2px;" /></figure>
				<figure class="panel" style="padding: 0.4rem; background: rgba(11,27,53,0.35);" data-reveal><img src="/images/gallery/gallery-4.png" alt="Inspiring gallery image 4" style="width:100%; height:210px; object-fit:cover; border-radius:2px;" /></figure>
				<figure class="panel" style="padding: 0.4rem; background: rgba(11,27,53,0.35);" data-reveal><img src="/images/gallery/gallery-5.png" alt="Inspiring gallery image 5" style="width:100%; height:210px; object-fit:cover; border-radius:2px;" /></figure>
				<figure class="panel" style="padding: 0.4rem; background: rgba(11,27,53,0.35);" data-reveal><img src="/images/gallery/gallery-6.png" alt="Inspiring gallery image 6" style="width:100%; height:210px; object-fit:cover; border-radius:2px;" /></figure>
				<figure class="panel" style="padding: 0.4rem; background: rgba(11,27,53,0.35);" data-reveal><img src="/images/gallery/gallery-7.png" alt="Inspiring gallery image 7" style="width:100%; height:210px; object-fit:cover; border-radius:2px;" /></figure>
				<figure class="panel" style="padding: 0.4rem; background: rgba(11,27,53,0.35);" data-reveal><img src="/images/gallery/gallery-8.png" alt="Inspiring gallery image 8" style="width:100%; height:210px; object-fit:cover; border-radius:2px;" /></figure>
			</div>
		</div>
	</main>
</Layout>

