---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Apply For A Record">
	<main class="section">
		<div class="container panel about-panel" data-reveal>
			<h2>Apply For A Record</h2>
			<p style="margin-top: -0.4rem; color: #d8e0ef; line-height: 1.6; max-width: 900px;">
				Submit your profile and record concept here. This category supports both <strong>new record creation</strong> and
				<strong>existing record breaking</strong> attempts.
			</p>

			<p id="applyAccountHint" style="margin-top: 0.5rem; color: #94a3b8; font-size: 0.88rem; display: none;"></p>

			<form class="apply-form" id="applyForm" action="#" method="post">
				<label class="apply-honeypot" aria-hidden="true">
					<span>Company</span>
					<input type="text" name="website" tabindex="-1" autocomplete="off" />
				</label>
				<label>
					Full Name
					<input type="text" name="fullName" required placeholder="Enter your full name" />
				</label>
				<label>
					Email Address
					<input type="email" name="email" required placeholder="Enter your email" />
				</label>
				<label>
					Phone / WhatsApp
					<input type="tel" name="phone" required placeholder="+91..." />
				</label>
				<label>
					City
					<input type="text" name="city" required placeholder="Your city" />
				</label>
				<label>
					Attempt Type
					<select name="attemptType" required>
						<option value="New Record Creation">New Record Creation</option>
						<option value="Existing Record Breaking">Existing Record Breaking</option>
					</select>
				</label>

				<label class="full">
					Applicant Overview
					<textarea name="overview" rows="4" required placeholder="Tell us about yourself and your achievement background"></textarea>
				</label>
				<label class="full">
					Record Attempt Details
					<textarea name="recordDetails" rows="5" required placeholder="Describe the proposed record, methodology and expected outcome"></textarea>
				</label>

				<label class="full" style="margin-top: 0.3rem;">
					<input type="checkbox" name="consent" required />
					I confirm that the information provided is accurate and I agree to be contacted by Paramount World Records.
				</label>

				<div class="full" style="margin-top: 0.4rem; display: flex; gap: 0.8rem; flex-wrap: wrap; align-items: center;">
					<button type="submit" class="btn btn-primary" id="applySubmitBtn">Submit Application</button>
					<a class="btn btn-ghost" href="mailto:admin@paramountworldrecords.com">Email Admin Instead</a>
				</div>
			</form>

			<p id="applyStatus" style="margin-top: 1rem; color: var(--text-secondary); display: none;"></p>
		</div>
	</main>

	<style>
		#applyForm {
			position: relative;
		}
		.apply-honeypot {
			position: absolute;
			left: -9999px;
			top: 0;
			width: 1px;
			height: 1px;
			overflow: hidden;
			clip: rect(0, 0, 0, 0);
		}
	</style>

	<script>
		import { getSupabase } from "../lib/supabaseBrowser";

		(function () {
			const form = document.getElementById("applyForm");
			const statusEl = document.getElementById("applyStatus");
			const submitBtn = document.getElementById("applySubmitBtn");
			const hint = document.getElementById("applyAccountHint");
			if (!form) return;

			async function showAccountHint() {
				const supabase = getSupabase();
				if (!supabase || !hint) return;
				const {
					data: { session },
				} = await supabase.auth.getSession();
				if (session?.user) {
					const meta = session.user.user_metadata ?? {};
					const label = (meta.name || meta.username || session.user.email || "your account").toString();
					hint.style.display = "block";
					hint.textContent = `Signed in as ${label}. This submission will be linked to your account and listed on your dashboard.`;
				}
			}
			showAccountHint();

			form.addEventListener("submit", async (e) => {
				e.preventDefault();
				if (statusEl) {
					statusEl.style.display = "none";
					statusEl.textContent = "";
				}
				if (submitBtn) {
					submitBtn.setAttribute("disabled", "disabled");
				}

				const fd = new FormData(form);
				const consentEl = form.querySelector('input[name="consent"]');
				const payload = {
					fullName: fd.get("fullName") || "",
					email: fd.get("email") || "",
					phone: fd.get("phone") || "",
					city: fd.get("city") || "",
					attemptType: fd.get("attemptType") || "",
					overview: fd.get("overview") || "",
					recordDetails: fd.get("recordDetails") || "",
					consent: consentEl instanceof HTMLInputElement && consentEl.checked === true,
					website: fd.get("website") || "",
				};

				const headers = { "Content-Type": "application/json" };
				const supabase = getSupabase();
				if (supabase) {
					const {
						data: { session },
					} = await supabase.auth.getSession();
					if (session?.access_token) {
						headers["Authorization"] = `Bearer ${session.access_token}`;
					}
				}

				try {
					const res = await fetch("/api/apply", {
						method: "POST",
						headers,
						body: JSON.stringify(payload),
					});
					const json = await res.json();
					const ok = typeof json === "object" && json && "ok" in json && json.ok === true;
					const errText =
						typeof json === "object" && json && "error" in json && typeof json.error === "string"
							? json.error
							: "";

					if (statusEl) {
						statusEl.style.display = "block";
					}
					if (res.ok && ok) {
						if (statusEl) {
							statusEl.style.color = "#15803d";
							statusEl.textContent =
								"Application received. We will contact you using the details you provided. You can also reach admin@paramountworldrecords.com if needed.";
						}
						form.reset();
					} else {
						if (statusEl) {
							statusEl.style.color = "#b91c1c";
							statusEl.textContent =
								errText || "Something went wrong. Please try again or use Email Admin Instead.";
						}
					}
				} catch {
					if (statusEl) {
						statusEl.style.display = "block";
						statusEl.style.color = "#b91c1c";
						statusEl.textContent = "Network error. Check your connection and try again.";
					}
				} finally {
					if (submitBtn) submitBtn.removeAttribute("disabled");
				}
			});
		})();
	</script>
</Layout>

