---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
	title: string;
	showChrome?: boolean;
}
const { title, showChrome = true } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="Independent record registry—authorisation, adjudication, verification, and certification." />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
			rel="stylesheet"
		/>
		<style is:global>
			:root {
				--navy: #070707;
				--accent: #6ea7d9;
				--accent-soft: #c7e2ff;
				--accent-deep: #2f628f;
				--accent-heading: #9ec8ef;
				--accent-glow: rgba(110, 167, 217, 0.24);
				--panel: rgba(20, 20, 20, 0.88);
				--panel-2: rgba(12, 12, 12, 0.92);
				--white: #ffffff;
				--link: #8fc6ff;
				--font-display: "Cormorant Garamond", Georgia, "Times New Roman", serif;
				--font-body: "Source Sans 3", system-ui, -apple-system, Segoe UI, sans-serif;
				--text-muted: #c5cedd;
			}

			* {
				box-sizing: border-box;
			}

			html,
			body {
				margin: 0;
				padding: 0;
			}

			body {
				min-height: 100vh;
				background:
					radial-gradient(circle at 16% -4%, var(--accent-glow), transparent 32%),
					radial-gradient(circle at 90% 6%, rgba(168, 189, 216, 0.1), transparent 30%),
					radial-gradient(ellipse 120% 80% at 50% 100%, rgba(30, 32, 38, 0.45), transparent 55%),
					linear-gradient(180deg, #0a0a0a 0%, #050505 100%);
				color: var(--white);
				font-family: var(--font-body);
				font-size: 1.02rem;
				line-height: 1.55;
				-webkit-font-smoothing: antialiased;
			}

			.container {
				width: min(1120px, 92%);
				margin: 0 auto;
			}

			.site-header {
				position: sticky;
				top: 0;
				z-index: 20;
				background: linear-gradient(180deg, rgba(16, 16, 16, 0.96) 0%, rgba(8, 8, 8, 0.94) 100%);
				backdrop-filter: blur(8px);
				border-bottom: 1px solid rgba(196, 194, 188, 0.3);
			}

			.nav-wrap {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				padding: 1rem 0;
			}

			.brand {
				display: inline-flex;
				align-items: center;
				gap: 0.55rem;
				text-decoration: none;
				color: var(--accent-heading);
				font-family: var(--font-display);
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				font-size: 0.88rem;
			}

			.brand img {
				height: 34px;
				width: auto;
				display: block;
			}

			.top-nav {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				justify-content: flex-end;
				gap: 0.8rem;
			}

			.top-nav a,
			.menu summary {
				color: #ffffff;
				text-decoration: none;
				font-size: 0.9rem;
				cursor: pointer;
			}

			.auth-nav-guest,
			.auth-nav-user {
				display: inline-flex;
				align-items: center;
				flex-wrap: wrap;
				gap: 0.65rem;
			}

			.auth-welcome {
				color: var(--accent-heading);
				font-size: 0.85rem;
				white-space: nowrap;
			}

			.auth-logout {
				cursor: pointer;
				border: 1px solid rgba(196, 194, 188, 0.45);
				background: rgba(12, 12, 12, 0.85);
				color: #e8e6e1;
				padding: 0.35rem 0.75rem;
				font-size: 0.78rem;
				border-radius: 2px;
				font-family: inherit;
			}

			.auth-logout:hover {
				border-color: rgba(168, 189, 216, 0.6);
				color: #fff;
			}

			.menu {
				position: relative;
			}

			.menu summary {
				list-style: none;
			}

			.menu summary::-webkit-details-marker {
				display: none;
			}

			.dropdown {
				position: absolute;
				right: 0;
				top: 1.4rem;
				display: grid;
				gap: 0.35rem;
				min-width: 240px;
				padding: 0.7rem;
				background: linear-gradient(180deg, #161616 0%, #0d0d0d 100%);
				border: 1px solid rgba(196, 194, 188, 0.38);
			}

			.section {
				padding: 5.25rem 0 2.25rem;
			}

			.panel {
				background: linear-gradient(160deg, var(--panel) 0%, var(--panel-2) 100%);
				border: 1px solid rgba(196, 194, 188, 0.32);
				padding: 1.2rem;
				border-radius: 2px;
				box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03), 0 10px 24px rgba(0, 0, 0, 0.34);
			}

			.hero-card {
				border: 1px solid rgba(196, 194, 188, 0.5);
				padding: clamp(1.4rem, 4vw, 3rem);
				background: radial-gradient(circle at top right, rgba(196, 194, 188, 0.1), transparent 45%);
				box-shadow: 0 20px 40px rgba(0, 0, 0, 0.35);
				text-align: center;
				border-radius: 2px;
			}

			.hero {
				padding-top: 2.25rem;
				padding-bottom: 0.5rem;
			}

			.tag {
				margin: 0;
				font-family: var(--font-display);
				text-transform: uppercase;
				font-size: 0.72rem;
				letter-spacing: 0.14em;
				color: #a8bdd8;
				font-weight: 600;
			}

			h1,
			h2,
			h3 {
				margin: 0 0 0.8rem;
			}

			h1,
			h2 {
				font-family: var(--font-display);
				font-weight: 700;
			}

			h1 {
				font-size: clamp(2.2rem, 6vw, 4.8rem);
				line-height: 1.03;
				text-transform: uppercase;
				color: var(--accent-heading);
				letter-spacing: 0.02em;
			}

			h1 span {
				color: #ffffff;
			}

			h2 {
				font-size: clamp(1.5rem, 3vw, 2rem);
				color: var(--accent-heading);
				letter-spacing: 0.01em;
			}

			h3 {
				font-family: var(--font-body);
				font-weight: 600;
			}

			.lead {
				font-size: clamp(1.02rem, 2.4vw, 1.28rem);
				max-width: 38rem;
				margin: 0.75rem auto 0;
				line-height: 1.65;
				color: var(--text-muted);
				font-weight: 400;
			}

			.btn {
				display: inline-block;
				padding: 0.85rem 1.25rem;
				text-decoration: none;
				border-radius: 2px;
				font-family: var(--font-body);
				font-weight: 700;
				text-transform: uppercase;
				font-size: 0.8rem;
				letter-spacing: 0.06em;
				transition: transform 0.15s ease, background-color 0.15s ease, border-color 0.15s ease, color 0.15s ease;
			}

			.btn-primary {
				background: linear-gradient(135deg, var(--accent-soft) 0%, var(--accent) 48%, var(--accent-deep) 100%);
				color: #141414;
				position: relative;
				overflow: hidden;
			}

			.btn-primary::after {
				content: "";
				position: absolute;
				top: -120%;
				left: -30%;
				width: 35%;
				height: 320%;
				transform: rotate(22deg);
				background: linear-gradient(
					90deg,
					rgba(255, 255, 255, 0) 0%,
					rgba(255, 255, 255, 0.55) 50%,
					rgba(255, 255, 255, 0) 100%
				);
				animation: accentShine 4s ease-in-out infinite;
				pointer-events: none;
			}

			.btn-ghost {
				border: 1px solid rgba(196, 194, 188, 0.5);
				color: #ffffff;
			}

			.btn:hover {
				transform: translateY(-1px);
			}

			.btn-ghost:hover {
				background: #ffffff;
				color: #101010;
			}

			.grid {
				display: grid;
				gap: 1rem;
			}

			.two {
				grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
			}

			.three {
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
			}

			.about-panel {
				position: relative;
				overflow: hidden;
			}

			.about-panel::before {
				content: "";
				position: absolute;
				inset: 0;
				background: url("/images/logo.png") center/340px no-repeat;
				opacity: 0.08;
				pointer-events: none;
			}

			.about-panel > * {
				position: relative;
				z-index: 1;
			}

			a {
				color: var(--link);
			}

			a:focus-visible,
			button:focus-visible,
			summary:focus-visible,
			input:focus-visible,
			select:focus-visible,
			textarea:focus-visible {
				outline: 2px solid rgba(168, 189, 216, 0.85);
				outline-offset: 2px;
			}

			.site-footer {
				padding: 2.1rem 0;
				border-top: 1px solid rgba(196, 194, 188, 0.3);
				margin-top: 2.2rem;
			}

			.footer-links {
				display: flex;
				flex-wrap: wrap;
				gap: 1rem;
				justify-content: center;
			}

			.footer-copy {
				margin-top: 1rem;
				text-align: center;
				color: #d8e0ef;
				font-size: 0.92rem;
			}

			/* Apply form */
			.apply-form {
				margin-top: 1rem;
				display: grid;
				grid-template-columns: repeat(2, minmax(180px, 1fr));
				gap: 0.8rem;
			}

			.apply-form label {
				display: grid;
				gap: 0.35rem;
				font-size: 0.92rem;
			}

			.apply-form input,
			.apply-form select,
			.apply-form textarea {
				width: 100%;
				border: 1px solid rgba(196, 194, 188, 0.38);
				background: rgba(3, 12, 26, 0.8);
				color: #ffffff;
				padding: 0.7rem;
				font: inherit;
				border-radius: 2px;
			}

			.apply-form .full {
				grid-column: 1 / -1;
			}

			/* Transitions / reveal animations */
			[data-reveal] {
				opacity: 0;
				transform: translateY(12px);
				transition: opacity 0.6s ease, transform 0.6s ease;
			}

			[data-reveal].is-visible {
				opacity: 1;
				transform: translateY(0);
			}

			@media (max-width: 880px) {
				.nav-wrap {
					flex-direction: column;
					align-items: flex-start;
				}

				.dropdown {
					left: 0;
					right: auto;
				}

				.apply-form {
					grid-template-columns: 1fr;
				}
			}

			/* Content helpers */
			.suggestions {
				margin: 0.7rem 0 0;
				padding-left: 1rem;
				display: grid;
				gap: 0.55rem;
			}

			.steps {
				margin: 0.8rem 0 0;
				padding-left: 1.1rem;
				display: grid;
				gap: 0.5rem;
			}

			.profile-grid {
				display: grid;
				gap: 1rem;
				grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
			}

			.profile-card {
				background: linear-gradient(160deg, var(--panel) 0%, var(--panel-2) 100%);
				border: 1px solid rgba(196, 194, 188, 0.32);
				padding: 1.2rem;
				border-radius: 2px;
				box-shadow: 0 14px 34px rgba(0, 0, 0, 0.42), inset 0 1px 0 rgba(255, 255, 255, 0.05);
			}

			.profile-avatar {
				width: 96px;
				height: 96px;
				border-radius: 50%;
				display: grid;
				place-items: center;
				margin-bottom: 0.9rem;
				background: radial-gradient(circle at top, rgba(196, 194, 188, 0.32), rgba(0, 0, 0, 0) 60%),
					#141414;
				border: 1px solid rgba(196, 194, 188, 0.38);
				color: var(--accent-heading);
				font-weight: 800;
				letter-spacing: 0.04em;
				text-transform: uppercase;
			}

			.profile-role {
				color: var(--accent-heading);
				font-weight: 700;
				margin: 0 0 0.6rem;
			}

			.profile-text {
				color: #e9f0ff;
				line-height: 1.6;
				font-size: 0.98rem;
			}

			.card-gloss {
				position: relative;
				overflow: hidden;
			}

			.card-gloss::before {
				content: "";
				position: absolute;
				inset: 0;
				background: linear-gradient(
					140deg,
					rgba(255, 255, 255, 0.1) 0%,
					rgba(255, 255, 255, 0.03) 26%,
					rgba(255, 255, 255, 0) 62%
				);
				pointer-events: none;
			}

			@keyframes accentShine {
				0% {
					left: -38%;
					opacity: 0;
				}
				12% {
					opacity: 1;
				}
				40% {
					left: 118%;
					opacity: 0;
				}
				100% {
					left: 118%;
					opacity: 0;
				}
			}
		</style>
	</head>
	<body>
		{showChrome ? <SiteHeader /> : null}
		<slot />
		{showChrome ? <SiteFooter /> : null}

		<script>
			import { getSupabase } from "../lib/supabaseBrowser";

			async function bindAuthNav() {
				const supabase = getSupabase();
				const guest = document.getElementById("authNavGuest");
				const userEl = document.getElementById("authNavUser");
				const nameEl = document.getElementById("authDisplayName");
				const btn = document.getElementById("authLogoutBtn");
				if (!guest || !userEl) return;

				function setMoreMenuAuth(show) {
					document.querySelectorAll("a.dropdown-account").forEach((el) => {
						if (el instanceof HTMLElement) el.hidden = !show;
					});
					document.querySelectorAll(".dropdown-rule").forEach((el) => {
						if (el instanceof HTMLElement) el.hidden = !show;
					});
				}

				async function refresh() {
					if (!supabase) {
						guest.hidden = false;
						userEl.hidden = true;
						setMoreMenuAuth(true);
						return;
					}
					const {
						data: { session },
					} = await supabase.auth.getSession();
					if (session?.user) {
						guest.hidden = true;
						userEl.hidden = false;
						setMoreMenuAuth(false);
						const meta = session.user.user_metadata ?? {};
						if (nameEl) {
							nameEl.textContent =
								(meta.name || meta.username || session.user.email || "").toString();
						}
					} else {
						guest.hidden = false;
						userEl.hidden = true;
						setMoreMenuAuth(true);
					}
				}

				await refresh();
				if (supabase) {
					supabase.auth.onAuthStateChange(() => {
						refresh();
					});
				}
				if (btn && !btn.dataset.bound) {
					btn.dataset.bound = "1";
					btn.addEventListener("click", async () => {
						if (supabase) await supabase.auth.signOut();
						await refresh();
						if (!["/login", "/register"].includes(location.pathname)) {
							window.location.href = "/home";
						}
					});
				}
			}

			document.addEventListener("DOMContentLoaded", bindAuthNav);
		</script>

		<script>
			(() => {
				const items = document.querySelectorAll("[data-reveal]");
				if (!items.length) return;

				const obs = new IntersectionObserver(
					(entries) => {
						for (const e of entries) {
							if (e.isIntersecting) {
								e.target.classList.add("is-visible");
								obs.unobserve(e.target);
							}
						}
					},
					{ threshold: 0.12 }
				);

				items.forEach((el) => obs.observe(el));
			})();
		</script>
	</body>
</html>
