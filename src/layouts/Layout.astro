---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
	title: string;
	showChrome?: boolean;
}
const { title, showChrome = true } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="Official world record registry." />
		<title>{title}</title>
		<style is:global>
			:root {
				--navy: #002147;
				--gold: #d4af37;
				--white: #ffffff;
			}

			* {
				box-sizing: border-box;
			}

			html,
			body {
				margin: 0;
				padding: 0;
			}

			body {
				min-height: 100vh;
				background: var(--navy);
				color: var(--white);
				font-family: Arial, Helvetica, sans-serif;
			}

			.container {
				width: min(1120px, 92%);
				margin: 0 auto;
			}

			.site-header {
				position: sticky;
				top: 0;
				z-index: 20;
				background: rgba(5, 18, 38, 0.92);
				backdrop-filter: blur(8px);
				border-bottom: 1px solid rgba(212, 175, 55, 0.25);
			}

			.nav-wrap {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				padding: 1rem 0;
			}

			.brand {
				display: inline-flex;
				align-items: center;
				gap: 0.55rem;
				text-decoration: none;
				color: #d4af37;
				font-weight: 700;
				letter-spacing: 0.04em;
				text-transform: uppercase;
				font-size: 0.92rem;
			}

			.brand img {
				height: 34px;
				width: auto;
				display: block;
			}

			.top-nav {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				justify-content: flex-end;
				gap: 0.8rem;
			}

			.top-nav a,
			.menu summary {
				color: #ffffff;
				text-decoration: none;
				font-size: 0.9rem;
				cursor: pointer;
			}

			.menu {
				position: relative;
			}

			.menu summary {
				list-style: none;
			}

			.menu summary::-webkit-details-marker {
				display: none;
			}

			.dropdown {
				position: absolute;
				right: 0;
				top: 1.4rem;
				display: grid;
				gap: 0.35rem;
				min-width: 240px;
				padding: 0.7rem;
				background: #0c1d39;
				border: 1px solid rgba(212, 175, 55, 0.35);
			}

			.section {
				padding: 4.5rem 0 1.5rem;
			}

			.panel {
				background: rgba(11, 27, 53, 0.92);
				border: 1px solid rgba(212, 175, 55, 0.3);
				padding: 1.2rem;
				border-radius: 2px;
			}

			.hero-card {
				border: 1px solid rgba(212, 175, 55, 0.5);
				padding: clamp(1.4rem, 4vw, 3rem);
				background: radial-gradient(circle at top right, rgba(212, 175, 55, 0.13), transparent 45%);
				box-shadow: 0 20px 40px rgba(0, 0, 0, 0.35);
				text-align: center;
				border-radius: 2px;
			}

			.hero {
				padding-top: 2.25rem;
				padding-bottom: 0.5rem;
			}

			.tag {
				margin: 0;
				text-transform: uppercase;
				font-size: 0.75rem;
				letter-spacing: 0.08em;
				color: #d4af37;
			}

			h1,
			h2,
			h3 {
				margin: 0 0 0.8rem;
			}

			h1 {
				font-size: clamp(2.2rem, 6vw, 4.8rem);
				line-height: 1.03;
				text-transform: uppercase;
				color: #d4af37;
			}

			h1 span {
				color: #ffffff;
			}

			h2 {
				font-size: clamp(1.5rem, 3vw, 2rem);
				color: #d4af37;
			}

			.lead {
				font-size: clamp(1rem, 2.7vw, 1.4rem);
				max-width: 850px;
				margin: 0.6rem auto 0;
			}

			.btn {
				display: inline-block;
				padding: 0.85rem 1.25rem;
				text-decoration: none;
				border-radius: 2px;
				font-weight: 700;
				text-transform: uppercase;
				font-size: 0.82rem;
				letter-spacing: 0.04em;
				transition: transform 0.15s ease, background-color 0.15s ease, border-color 0.15s ease, color 0.15s ease;
			}

			.btn-primary {
				background: #d4af37;
				color: #061736;
			}

			.btn-ghost {
				border: 1px solid rgba(212, 175, 55, 0.5);
				color: #ffffff;
			}

			.btn:hover {
				transform: translateY(-1px);
			}

			.btn-ghost:hover {
				background: #ffffff;
				color: #061736;
			}

			.grid {
				display: grid;
				gap: 1rem;
			}

			.two {
				grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
			}

			.three {
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
			}

			.about-panel {
				position: relative;
				overflow: hidden;
			}

			.about-panel::before {
				content: "";
				position: absolute;
				inset: 0;
				background: url("/images/logo.png") center/340px no-repeat;
				opacity: 0.08;
				pointer-events: none;
			}

			.about-panel > * {
				position: relative;
				z-index: 1;
			}

			a {
				color: #f0d98a;
			}

			.site-footer {
				padding: 2.1rem 0;
				border-top: 1px solid rgba(212, 175, 55, 0.25);
				margin-top: 2.2rem;
			}

			.footer-links {
				display: flex;
				flex-wrap: wrap;
				gap: 1rem;
				justify-content: center;
			}

			.footer-copy {
				margin-top: 1rem;
				text-align: center;
				color: #d8e0ef;
				font-size: 0.92rem;
			}

			/* Apply form */
			.apply-form {
				margin-top: 1rem;
				display: grid;
				grid-template-columns: repeat(2, minmax(180px, 1fr));
				gap: 0.8rem;
			}

			.apply-form label {
				display: grid;
				gap: 0.35rem;
				font-size: 0.92rem;
			}

			.apply-form input,
			.apply-form select,
			.apply-form textarea {
				width: 100%;
				border: 1px solid rgba(212, 175, 55, 0.35);
				background: rgba(3, 12, 26, 0.8);
				color: #ffffff;
				padding: 0.7rem;
				font: inherit;
				border-radius: 2px;
			}

			.apply-form .full {
				grid-column: 1 / -1;
			}

			/* Transitions / reveal animations */
			[data-reveal] {
				opacity: 0;
				transform: translateY(12px);
				transition: opacity 0.6s ease, transform 0.6s ease;
			}

			[data-reveal].is-visible {
				opacity: 1;
				transform: translateY(0);
			}

			@media (max-width: 880px) {
				.nav-wrap {
					flex-direction: column;
					align-items: flex-start;
				}

				.dropdown {
					left: 0;
					right: auto;
				}

				.apply-form {
					grid-template-columns: 1fr;
				}
			}

			/* Content helpers */
			.suggestions {
				margin: 0.7rem 0 0;
				padding-left: 1rem;
				display: grid;
				gap: 0.55rem;
			}

			.steps {
				margin: 0.8rem 0 0;
				padding-left: 1.1rem;
				display: grid;
				gap: 0.5rem;
			}

			.profile-grid {
				display: grid;
				gap: 1rem;
				grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
			}

			.profile-card {
				background: rgba(11, 27, 53, 0.92);
				border: 1px solid rgba(212, 175, 55, 0.3);
				padding: 1.2rem;
				border-radius: 2px;
			}

			.profile-avatar {
				width: 96px;
				height: 96px;
				border-radius: 50%;
				display: grid;
				place-items: center;
				margin-bottom: 0.9rem;
				background: radial-gradient(circle at top, rgba(212, 175, 55, 0.35), rgba(0, 0, 0, 0) 60%),
					#0c1d39;
				border: 1px solid rgba(212, 175, 55, 0.35);
				color: #d4af37;
				font-weight: 800;
				letter-spacing: 0.04em;
				text-transform: uppercase;
			}

			.profile-role {
				color: #d4af37;
				font-weight: 700;
				margin: 0 0 0.6rem;
			}

			.profile-text {
				color: #e9f0ff;
				line-height: 1.6;
				font-size: 0.98rem;
			}
		</style>
	</head>
	<body>
		{showChrome ? <SiteHeader /> : null}
		<slot />
		{showChrome ? <SiteFooter /> : null}

		<script>
			(() => {
				const items = document.querySelectorAll("[data-reveal]");
				if (!items.length) return;

				const obs = new IntersectionObserver(
					(entries) => {
						for (const e of entries) {
							if (e.isIntersecting) {
								e.target.classList.add("is-visible");
								obs.unobserve(e.target);
							}
						}
					},
					{ threshold: 0.12 }
				);

				items.forEach((el) => obs.observe(el));
			})();
		</script>
	</body>
</html>
