---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
	title: string;
	showChrome?: boolean;
}
const { title, showChrome = true } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="Independent record registry—authorisation, adjudication, verification, and certification." />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap"
			rel="stylesheet"
		/>
		<style is:global>
			/* Platinum Prestige — soft ivory, sage containers, authoritative type */
			:root {
				--bg-ivory: #e4e4de;
				--bg-sage: #c4c5ba;
				--bg-sage-deep: #b0b1a5;
				--border-sage: #a3a494;
				--text-primary: #1b1b1b;
				--text-secondary: #2c2c2c;
				--text-muted: #3d3d3d;
				--white: #ffffff;
				--link: #1b1b1b;
				--accent: #1b1b1b;
				--accent-heading: #1b1b1b;
				--font-display: "Playfair Display", Georgia, "Times New Roman", serif;
				--font-body: "Inter", system-ui, -apple-system, Segoe UI, sans-serif;
				--radius-premium: 2px;
				--shadow-soft: 0 16px 48px rgba(27, 27, 27, 0.07);
				--shadow-soft-sm: 0 8px 24px rgba(27, 27, 27, 0.05);
				--panel: #c4c5ba;
				--panel-2: #b8b9ae;
			}

			* {
				box-sizing: border-box;
			}

			html,
			body {
				margin: 0;
				padding: 0;
			}

			body {
				min-height: 100vh;
				background: var(--bg-ivory);
				color: var(--text-primary);
				font-family: var(--font-body);
				font-size: 1.05rem;
				line-height: 1.65;
				letter-spacing: 0.01em;
				-webkit-font-smoothing: antialiased;
			}

			p,
			li {
				line-height: 1.7;
			}

			.container {
				width: min(1120px, 92%);
				margin: 0 auto;
			}

			.site-header {
				position: sticky;
				top: 0;
				z-index: 20;
				background: rgba(228, 228, 222, 0.82);
				backdrop-filter: blur(14px);
				-webkit-backdrop-filter: blur(14px);
				border-bottom: 1px solid var(--border-sage);
				transition: background-color 0.35s ease, box-shadow 0.35s ease;
			}

			.site-header.scrolled {
				background: rgba(228, 228, 222, 0.96);
				box-shadow: var(--shadow-soft-sm);
			}

			.nav-wrap {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				padding: 1rem 0;
			}

			.brand {
				display: inline-flex;
				align-items: center;
				gap: 0.55rem;
				text-decoration: none;
				color: var(--text-primary);
				font-family: var(--font-display);
				font-weight: 600;
				letter-spacing: 0.06em;
				text-transform: none;
				font-size: 0.95rem;
			}

			.brand img {
				height: 34px;
				width: auto;
				display: block;
			}

			.top-nav {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				justify-content: flex-end;
				gap: 0.8rem;
			}

			.top-nav a,
			.menu summary {
				color: var(--text-secondary);
				text-decoration: none;
				font-size: 0.88rem;
				cursor: pointer;
				font-weight: 500;
				letter-spacing: 0.04em;
			}

			.auth-nav-guest,
			.auth-nav-user {
				display: inline-flex;
				align-items: center;
				flex-wrap: wrap;
				gap: 0.65rem;
			}

			.auth-welcome {
				color: var(--text-secondary);
				font-size: 0.85rem;
				white-space: nowrap;
			}

			.auth-logout {
				cursor: pointer;
				border: 1px solid var(--border-sage);
				background: transparent;
				color: var(--text-primary);
				padding: 0.4rem 0.85rem;
				font-size: 0.78rem;
				border-radius: var(--radius-premium);
				font-family: inherit;
				transition: background 0.2s ease, border-color 0.2s ease;
			}

			.auth-logout:hover {
				border-color: var(--text-primary);
				background: rgba(255, 255, 255, 0.35);
			}

			.menu {
				position: relative;
			}

			.menu summary {
				list-style: none;
			}

			.menu summary::-webkit-details-marker {
				display: none;
			}

			.dropdown {
				position: absolute;
				right: 0;
				top: 1.4rem;
				display: grid;
				gap: 0.35rem;
				min-width: 240px;
				padding: 0.75rem;
				background: var(--bg-ivory);
				border: 1px solid var(--border-sage);
				box-shadow: var(--shadow-soft-sm);
			}

			.section {
				padding: clamp(4.5rem, 10vw, 7.5rem) 0 clamp(3.5rem, 8vw, 5rem);
			}

			.panel {
				background: linear-gradient(165deg, var(--panel) 0%, var(--panel-2) 100%);
				border: 1px solid var(--border-sage);
				padding: clamp(1.75rem, 4vw, 2.5rem);
				border-radius: var(--radius-premium);
				box-shadow: var(--shadow-soft-sm);
				transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
			}

			.hero-card {
				border: 1px solid var(--border-sage);
				padding: clamp(1.4rem, 4vw, 3rem);
				background: linear-gradient(165deg, var(--panel) 0%, var(--panel-2) 100%);
				box-shadow: var(--shadow-soft-sm);
				text-align: center;
				border-radius: var(--radius-premium);
			}

			.hero {
				padding-top: 2.25rem;
				padding-bottom: 0.5rem;
			}

			.tag {
				margin: 0;
				font-family: var(--font-body);
				text-transform: uppercase;
				font-size: 0.68rem;
				letter-spacing: 0.2em;
				color: var(--text-secondary);
				font-weight: 600;
			}

			h1,
			h2,
			h3 {
				margin: 0 0 0.8rem;
			}

			h1,
			h2 {
				font-family: var(--font-display);
				font-weight: 600;
				color: var(--text-primary);
				-webkit-background-clip: unset;
				background: none;
				background-clip: unset;
				-webkit-text-stroke: 0;
				text-shadow: none;
			}

			h1 {
				font-size: clamp(2.2rem, 6vw, 4.8rem);
				line-height: 1.08;
				text-transform: none;
				letter-spacing: -0.02em;
			}

			h1 span {
				color: var(--text-primary);
				background: none;
				-webkit-background-clip: unset;
				background-clip: unset;
				-webkit-text-stroke: 0;
			}

			h2 {
				font-size: clamp(1.65rem, 3.2vw, 2.35rem);
				letter-spacing: -0.015em;
				text-transform: none;
			}

			h3 {
				font-family: var(--font-body);
				font-weight: 600;
				color: var(--text-primary);
			}

			.lead {
				font-size: clamp(1.02rem, 2.4vw, 1.28rem);
				max-width: 38rem;
				margin: 0.75rem auto 0;
				line-height: 1.7;
				color: var(--text-secondary);
				font-weight: 400;
			}

			.btn {
				display: inline-block;
				padding: 0.9rem 1.34rem;
				text-decoration: none;
				border-radius: 999px;
				font-family: var(--font-body);
				font-weight: 700;
				text-transform: uppercase;
				font-size: 0.76rem;
				letter-spacing: 0.1em;
				transition: transform 0.28s ease, background-color 0.28s ease, border-color 0.28s ease, color 0.28s ease, box-shadow 0.28s ease;
			}

			.btn-primary {
				background: var(--text-primary);
				color: var(--bg-ivory);
				position: relative;
				overflow: hidden;
				box-shadow: var(--shadow-soft-sm);
				border: 1px solid var(--text-primary);
			}

			.btn-primary::after {
				display: none;
			}

			.btn-ghost {
				border: 1px solid var(--border-sage);
				color: var(--text-primary);
				background: transparent;
			}

			.btn:hover {
				transform: translateY(-2px);
				box-shadow: var(--shadow-soft);
			}

			.btn-primary:hover {
				background: var(--text-secondary);
				border-color: var(--text-secondary);
				color: var(--bg-ivory);
			}

			.btn-ghost:hover {
				background: var(--bg-sage);
				color: var(--text-primary);
				border-color: var(--text-primary);
			}

			.grid {
				display: grid;
				gap: 1rem;
			}

			.two {
				grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
			}

			.three {
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
			}

			.about-panel {
				position: relative;
				overflow: hidden;
			}

			.about-panel::before {
				content: "";
				position: absolute;
				inset: 0;
				background: url("/images/logo.png") center/340px no-repeat;
				opacity: 0.06;
				filter: brightness(0.55);
				pointer-events: none;
			}

			.about-panel > * {
				position: relative;
				z-index: 1;
			}

			a {
				color: var(--link);
				text-decoration: none;
				text-underline-offset: 0.2em;
				transition: color 0.2s ease, opacity 0.2s ease;
			}

			a:hover {
				opacity: 0.75;
			}

			.brand:hover,
			.top-nav a:hover,
			.menu summary:hover {
				opacity: 1;
			}

			.top-nav a,
			.menu summary {
				background: none;
				-webkit-background-clip: unset;
				background-clip: unset;
				color: var(--text-secondary) !important;
				-webkit-text-stroke: 0;
				text-shadow: none;
			}

			a:focus-visible,
			button:focus-visible,
			summary:focus-visible,
			input:focus-visible,
			select:focus-visible,
			textarea:focus-visible {
				outline: 2px solid var(--border-sage);
				outline-offset: 3px;
			}

			.site-footer {
				padding: clamp(3rem, 6vw, 4rem) 0;
				border-top: 1px solid var(--border-sage);
				margin-top: clamp(3rem, 8vw, 5rem);
				background: var(--bg-ivory);
			}

			.footer-links {
				display: flex;
				flex-wrap: wrap;
				gap: 1rem;
				justify-content: center;
			}

			.footer-links a {
				color: var(--text-secondary);
				font-size: 0.88rem;
				letter-spacing: 0.06em;
			}

			.footer-links a:hover {
				color: var(--text-primary);
				opacity: 1;
			}

			.footer-copy {
				margin-top: 1.35rem;
				text-align: center;
				color: var(--text-secondary);
				font-size: 0.82rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
			}

			/* Apply form */
			.apply-form {
				margin-top: 1rem;
				display: grid;
				grid-template-columns: repeat(2, minmax(180px, 1fr));
				gap: 0.8rem;
			}

			.apply-form label {
				display: grid;
				gap: 0.35rem;
				font-size: 0.92rem;
			}

			.apply-form input,
			.apply-form select,
			.apply-form textarea {
				width: 100%;
				border: 1px solid var(--border-sage);
				background: var(--white);
				color: var(--text-primary);
				padding: 0.75rem;
				font: inherit;
				border-radius: var(--radius-premium);
			}

			.apply-form .full {
				grid-column: 1 / -1;
			}

			/* Transitions / reveal animations */
			[data-reveal] {
				opacity: 0;
				transform: translateY(28px);
				transition:
					opacity 1s cubic-bezier(0.22, 1, 0.36, 1),
					transform 1s cubic-bezier(0.22, 1, 0.36, 1);
			}

			[data-reveal].is-visible {
				opacity: 1;
				transform: translateY(0);
			}

			@media (hover: hover) and (pointer: fine) {
				.panel:hover {
					transform: translateY(-3px);
					box-shadow: var(--shadow-soft);
					border-color: var(--text-secondary);
				}
			}

			@media (max-width: 880px) {
				.nav-wrap {
					flex-direction: column;
					align-items: flex-start;
				}

				.dropdown {
					left: 0;
					right: auto;
				}

				.apply-form {
					grid-template-columns: 1fr;
				}
			}

			/* Content helpers */
			.suggestions {
				margin: 0.7rem 0 0;
				padding-left: 1rem;
				display: grid;
				gap: 0.55rem;
			}

			.steps {
				margin: 0.8rem 0 0;
				padding-left: 1.1rem;
				display: grid;
				gap: 0.5rem;
			}

			.profile-grid {
				display: grid;
				gap: 1rem;
				grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
			}

			.profile-card {
				background: linear-gradient(165deg, var(--panel) 0%, var(--panel-2) 100%);
				border: 1px solid var(--border-sage);
				padding: 1.2rem;
				border-radius: var(--radius-premium);
				box-shadow: var(--shadow-soft-sm);
			}

			.profile-avatar {
				width: 96px;
				height: 96px;
				border-radius: 50%;
				display: grid;
				place-items: center;
				margin-bottom: 0.9rem;
				background: var(--bg-ivory);
				border: 1px solid var(--border-sage);
				color: var(--text-primary);
				font-weight: 800;
				letter-spacing: 0.04em;
				text-transform: uppercase;
			}

			.profile-role {
				color: var(--text-primary);
				font-family: var(--font-display);
				font-weight: 600;
				margin: 0 0 0.6rem;
			}

			.profile-text {
				color: var(--text-secondary);
				line-height: 1.6;
				font-size: 0.98rem;
			}

			.card-gloss {
				position: relative;
				overflow: hidden;
			}

			.card-gloss::before {
				content: "";
				position: absolute;
				inset: 0;
				background: linear-gradient(
					140deg,
					rgba(255, 255, 255, 0.1) 0%,
					rgba(255, 255, 255, 0.03) 26%,
					rgba(255, 255, 255, 0) 62%
				);
				pointer-events: none;
			}

			@keyframes accentShine {
				0% {
					left: -38%;
					opacity: 0;
				}
				12% {
					opacity: 1;
				}
				40% {
					left: 118%;
					opacity: 0;
				}
				100% {
					left: 118%;
					opacity: 0;
				}
			}
		</style>
	</head>
	<body>
		{showChrome ? <SiteHeader /> : null}
		<slot />
		{showChrome ? <SiteFooter /> : null}

		<script>
			import { getSupabase } from "../lib/supabaseBrowser";

			async function bindAuthNav() {
				const supabase = getSupabase();
				const guest = document.getElementById("authNavGuest");
				const userEl = document.getElementById("authNavUser");
				const nameEl = document.getElementById("authDisplayName");
				const btn = document.getElementById("authLogoutBtn");
				if (!guest || !userEl) return;

				function setMoreMenuAuth(show) {
					document.querySelectorAll("a.dropdown-account").forEach((el) => {
						if (el instanceof HTMLElement) el.hidden = !show;
					});
					document.querySelectorAll(".dropdown-rule").forEach((el) => {
						if (el instanceof HTMLElement) el.hidden = !show;
					});
				}

				async function refresh() {
					if (!supabase) {
						guest.hidden = false;
						userEl.hidden = true;
						setMoreMenuAuth(true);
						return;
					}
					const {
						data: { session },
					} = await supabase.auth.getSession();
					if (session?.user) {
						guest.hidden = true;
						userEl.hidden = false;
						setMoreMenuAuth(false);
						const meta = session.user.user_metadata ?? {};
						if (nameEl) {
							nameEl.textContent =
								(meta.name || meta.username || session.user.email || "").toString();
						}
					} else {
						guest.hidden = false;
						userEl.hidden = true;
						setMoreMenuAuth(true);
					}
				}

				await refresh();
				if (supabase) {
					supabase.auth.onAuthStateChange(() => {
						refresh();
					});
				}
				if (btn && !btn.dataset.bound) {
					btn.dataset.bound = "1";
					btn.addEventListener("click", async () => {
						if (supabase) await supabase.auth.signOut();
						await refresh();
						if (!["/login", "/register"].includes(location.pathname)) {
							window.location.href = "/home";
						}
					});
				}
			}

			document.addEventListener("DOMContentLoaded", bindAuthNav);
		</script>

		<script>
			(() => {
				const header = document.querySelector(".site-header");
				if (!(header instanceof HTMLElement)) return;

				const update = () => {
					header.classList.toggle("scrolled", window.scrollY > 18);
				};

				update();
				window.addEventListener("scroll", update, { passive: true });
			})();
		</script>

		<script>
			(() => {
				const items = document.querySelectorAll("[data-reveal]");
				if (!items.length) return;

				const obs = new IntersectionObserver(
					(entries) => {
						for (const e of entries) {
							if (e.isIntersecting) {
								e.target.classList.add("is-visible");
								obs.unobserve(e.target);
							}
						}
					},
					{ threshold: 0.12 }
				);

				items.forEach((el) => obs.observe(el));
			})();
		</script>
	</body>
</html>
