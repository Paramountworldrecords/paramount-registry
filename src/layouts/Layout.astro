---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
	title: string;
	showChrome?: boolean;
}
const { title, showChrome = true } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="theme-color" content="#080808" />
		<meta name="description" content="Independent record registry—authorisation, adjudication, verification, and certification." />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Anton&family=Montserrat:wght@300;400;500;600&family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600&display=swap"
			rel="stylesheet"
		/>
		<style is:global>
			/* Modern Noir — deep matte black, white type, teal mist, stoplight punctuation only */
			:root {
				--bg-noir: #080808;
				--surface-noir: #121212;
				--border-noir: #1f1f1f;
				--text-primary: #ffffff;
				--text-secondary: rgba(255, 255, 255, 0.72);
				--text-muted: rgba(255, 255, 255, 0.55);
				--mist: rgba(0, 201, 167, 0.15);
				--mist-soft: rgba(0, 201, 167, 0.08);
				--mist-glow: rgba(0, 201, 167, 0.22);
				--stoplight: #ff0000;
				--white: #ffffff;
				--link: #ffffff;
				--accent: #ffffff;
				--accent-heading: #ffffff;
				--font-hero: "Anton", Impact, "Arial Narrow", sans-serif;
				--font-label: "Montserrat", system-ui, sans-serif;
				--font-body: "Inter", system-ui, -apple-system, Segoe UI, sans-serif;
				--radius-card: 24px;
				--radius-premium: 24px;
				--panel: #121212;
				--panel-2: #121212;
				--shadow-soft: 0 24px 64px rgba(0, 0, 0, 0.45);
				--shadow-soft-sm: 0 12px 32px rgba(0, 0, 0, 0.35);
			}

			* {
				box-sizing: border-box;
			}

			html {
				color-scheme: dark;
			}

			html,
			body {
				margin: 0;
				padding: 0;
			}

			body {
				min-height: 100vh;
				background: var(--bg-noir);
				color: var(--text-primary);
				font-family: var(--font-body);
				font-size: 1rem;
				line-height: 1.65;
				letter-spacing: 0.02em;
				-webkit-font-smoothing: antialiased;
			}

			p,
			li {
				line-height: 1.7;
			}

			.container {
				width: min(1120px, 92%);
				margin: 0 auto;
			}

			.site-header {
				position: sticky;
				top: 0;
				z-index: 20;
				background: rgba(8, 8, 8, 0.82);
				backdrop-filter: blur(16px);
				-webkit-backdrop-filter: blur(16px);
				border-bottom: 1px solid var(--border-noir);
				transition: background-color 0.35s ease, box-shadow 0.35s ease;
			}

			.site-header.scrolled {
				background: rgba(8, 8, 8, 0.94);
				box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
			}

			.nav-wrap {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				padding: 1rem 0;
			}

			.brand {
				display: inline-flex;
				align-items: center;
				gap: 0.55rem;
				text-decoration: none;
				color: var(--text-primary);
				font-family: var(--font-label);
				font-weight: 500;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				font-size: 0.68rem;
			}

			.brand img {
				height: 34px;
				width: auto;
				display: block;
			}

			.top-nav {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				justify-content: flex-end;
				gap: 0.8rem;
			}

			.top-nav a,
			.menu summary {
				color: var(--text-secondary);
				text-decoration: none;
				font-size: 0.72rem;
				cursor: pointer;
				font-weight: 400;
				font-family: var(--font-label);
				letter-spacing: 0.2em;
				text-transform: uppercase;
			}

			.auth-nav-guest,
			.auth-nav-user {
				display: inline-flex;
				align-items: center;
				flex-wrap: wrap;
				gap: 0.65rem;
			}

			.auth-welcome {
				color: var(--text-secondary);
				font-size: 0.85rem;
				white-space: nowrap;
			}

			.auth-logout {
				cursor: pointer;
				border: 1px solid var(--border-noir);
				background: var(--surface-noir);
				color: var(--text-primary);
				padding: 0.4rem 0.85rem;
				font-size: 0.72rem;
				border-radius: var(--radius-card);
				font-family: var(--font-label);
				letter-spacing: 0.14em;
				text-transform: uppercase;
				transition: border-color 0.2s ease, color 0.2s ease;
			}

			.auth-logout:hover {
				border-color: var(--text-primary);
			}

			.menu {
				position: relative;
			}

			.menu summary {
				list-style: none;
			}

			.menu summary::-webkit-details-marker {
				display: none;
			}

			.dropdown {
				position: absolute;
				right: 0;
				top: 1.4rem;
				display: grid;
				gap: 0.35rem;
				min-width: 240px;
				padding: 0.85rem;
				background: var(--surface-noir);
				border: 1px solid var(--border-noir);
				border-radius: var(--radius-card);
				box-shadow: var(--shadow-soft-sm);
			}

			.section {
				padding: clamp(4.5rem, 10vw, 7.5rem) 0 clamp(3.5rem, 8vw, 5rem);
			}

			.panel {
				background: var(--surface-noir);
				border: 1px solid var(--border-noir);
				padding: clamp(1.75rem, 4vw, 2.5rem);
				border-radius: var(--radius-card);
				box-shadow: var(--shadow-soft-sm);
				transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
			}

			.hero-card {
				border: 1px solid var(--border-noir);
				padding: clamp(1.4rem, 4vw, 3rem);
				background: var(--surface-noir);
				box-shadow: var(--shadow-soft-sm);
				text-align: center;
				border-radius: var(--radius-card);
			}

			.hero {
				padding-top: 2.25rem;
				padding-bottom: 0.5rem;
			}

			.tag {
				margin: 0;
				font-family: var(--font-label);
				text-transform: uppercase;
				font-size: 0.65rem;
				letter-spacing: 0.2em;
				color: var(--text-muted);
				font-weight: 300;
			}

			h1,
			h2,
			h3 {
				margin: 0 0 0.8rem;
			}

			h1,
			h2 {
				font-family: var(--font-hero);
				font-weight: 400;
				color: var(--text-primary);
				text-transform: uppercase;
				letter-spacing: -0.04em;
				line-height: 0.98;
				-webkit-background-clip: unset;
				background: none;
				background-clip: unset;
				-webkit-text-stroke: 0;
				text-shadow: none;
			}

			h1 {
				font-size: clamp(2.75rem, 10vw, 6.5rem);
			}

			h1 span {
				color: var(--text-primary);
				background: none;
				-webkit-background-clip: unset;
				background-clip: unset;
				-webkit-text-stroke: 0;
			}

			h2 {
				font-size: clamp(2rem, 6vw, 3.75rem);
				letter-spacing: -0.035em;
			}

			h3 {
				font-family: var(--font-label);
				font-weight: 600;
				color: var(--text-primary);
				letter-spacing: 0.2em;
				text-transform: uppercase;
				font-size: 0.78rem;
			}

			.lead {
				font-size: clamp(1.02rem, 2.4vw, 1.2rem);
				max-width: 38rem;
				margin: 0.75rem auto 0;
				line-height: 1.75;
				color: var(--text-secondary);
				font-weight: 400;
				font-family: var(--font-body);
			}

			/* Stoplight red: use .stoplight on punctuation or .underline-stoplight for 1px accent */
			.stoplight {
				color: var(--stoplight);
			}

			.underline-stoplight {
				text-decoration: none;
				border-bottom: 1px solid var(--stoplight);
				padding-bottom: 0.12em;
			}

			.btn {
				display: inline-block;
				padding: 1rem 1.5rem;
				text-decoration: none;
				border-radius: var(--radius-card);
				font-family: var(--font-label);
				font-weight: 500;
				text-transform: uppercase;
				font-size: 0.68rem;
				letter-spacing: 0.2em;
				transition: transform 0.28s ease, background-color 0.28s ease, border-color 0.28s ease, color 0.28s ease, box-shadow 0.28s ease;
			}

			.btn-primary {
				background: var(--text-primary);
				color: var(--bg-noir);
				position: relative;
				overflow: hidden;
				box-shadow: 0 0 32px rgba(0, 201, 167, 0.12);
				border: 1px solid var(--text-primary);
			}

			.btn-primary::after {
				display: none;
			}

			.btn-ghost {
				border: 1px solid var(--border-noir);
				color: var(--text-primary);
				background: transparent;
			}

			.btn:hover {
				transform: translateY(-2px);
				box-shadow: var(--shadow-soft-sm);
			}

			.btn-primary:hover {
				background: rgba(255, 255, 255, 0.92);
				border-color: #ffffff;
				color: var(--bg-noir);
			}

			.btn-ghost:hover {
				background: var(--surface-noir);
				border-color: var(--text-primary);
				color: var(--text-primary);
			}

			.grid {
				display: grid;
				gap: 1rem;
			}

			.two {
				grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
			}

			.three {
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
			}

			.about-panel {
				position: relative;
				overflow: hidden;
			}

			.about-panel::before {
				content: "";
				position: absolute;
				inset: 0;
				background: url("/images/logo.png") center/340px no-repeat;
				opacity: 0.04;
				filter: brightness(0) invert(1);
				pointer-events: none;
			}

			.about-panel > * {
				position: relative;
				z-index: 1;
			}

			a {
				color: var(--link);
				text-decoration: none;
				text-underline-offset: 0.2em;
				transition: color 0.2s ease, opacity 0.2s ease;
			}

			a:hover {
				opacity: 0.75;
			}

			.brand:hover,
			.top-nav a:hover,
			.menu summary:hover {
				opacity: 1;
			}

			.top-nav a,
			.menu summary {
				background: none;
				-webkit-background-clip: unset;
				background-clip: unset;
				color: var(--text-secondary) !important;
				-webkit-text-stroke: 0;
				text-shadow: none;
			}

			a:focus-visible,
			button:focus-visible,
			summary:focus-visible,
			input:focus-visible,
			select:focus-visible,
			textarea:focus-visible {
				outline: 2px solid var(--mist-glow);
				outline-offset: 3px;
			}

			.site-footer {
				padding: clamp(3rem, 6vw, 4rem) 0;
				border-top: 1px solid var(--border-noir);
				margin-top: clamp(3rem, 8vw, 5rem);
				background: var(--bg-noir);
			}

			.footer-links {
				display: flex;
				flex-wrap: wrap;
				gap: 1rem;
				justify-content: center;
			}

			.footer-links a {
				color: var(--text-muted);
				font-size: 0.68rem;
				font-family: var(--font-label);
				letter-spacing: 0.2em;
				text-transform: uppercase;
			}

			.footer-links a:hover {
				color: var(--text-primary);
				opacity: 1;
			}

			.footer-copy {
				margin-top: 1.35rem;
				text-align: center;
				color: var(--text-muted);
				font-size: 0.65rem;
				font-family: var(--font-label);
				letter-spacing: 0.2em;
				text-transform: uppercase;
			}

			/* Apply form */
			.apply-form {
				margin-top: 1rem;
				display: grid;
				grid-template-columns: repeat(2, minmax(180px, 1fr));
				gap: 0.8rem;
			}

			.apply-form label {
				display: grid;
				gap: 0.35rem;
				font-size: 0.68rem;
				color: rgba(255, 255, 255, 0.85);
				font-family: var(--font-label);
				letter-spacing: 0.12em;
				text-transform: uppercase;
				font-weight: 400;
			}

			.apply-form input,
			.apply-form select,
			.apply-form textarea {
				width: 100%;
				border: 1px solid var(--border-noir);
				background: var(--surface-noir);
				color: var(--text-primary);
				padding: 0.75rem;
				font: inherit;
				border-radius: var(--radius-card);
			}

			.apply-form .full {
				grid-column: 1 / -1;
			}

			/* Transitions / reveal animations */
			[data-reveal] {
				opacity: 0;
				transform: translateY(28px);
				transition:
					opacity 1s cubic-bezier(0.22, 1, 0.36, 1),
					transform 1s cubic-bezier(0.22, 1, 0.36, 1);
			}

			[data-reveal].is-visible {
				opacity: 1;
				transform: translateY(0);
			}

			@media (hover: hover) and (pointer: fine) {
				.panel:hover {
					transform: translateY(-4px);
					box-shadow: var(--shadow-soft);
					border-color: rgba(0, 201, 167, 0.25);
				}
			}

			@media (max-width: 880px) {
				.nav-wrap {
					flex-direction: column;
					align-items: flex-start;
				}

				.dropdown {
					left: 0;
					right: auto;
				}

				.apply-form {
					grid-template-columns: 1fr;
				}
			}

			/* Content helpers */
			.suggestions {
				margin: 0.7rem 0 0;
				padding-left: 1rem;
				display: grid;
				gap: 0.55rem;
			}

			.steps {
				margin: 0.8rem 0 0;
				padding-left: 1.1rem;
				display: grid;
				gap: 0.5rem;
			}

			.profile-grid {
				display: grid;
				gap: 1rem;
				grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
			}

			.profile-card {
				background: var(--surface-noir);
				border: 1px solid var(--border-noir);
				padding: 1.2rem;
				border-radius: var(--radius-card);
				box-shadow: var(--shadow-soft-sm);
			}

			.profile-avatar {
				width: 96px;
				height: 96px;
				border-radius: 50%;
				display: grid;
				place-items: center;
				margin-bottom: 0.9rem;
				background: var(--bg-noir);
				border: 1px solid var(--border-noir);
				color: var(--text-primary);
				font-weight: 800;
				letter-spacing: 0.04em;
				text-transform: uppercase;
			}

			.profile-role {
				color: var(--text-primary);
				font-family: var(--font-hero);
				font-weight: 400;
				font-size: 1.25rem;
				letter-spacing: -0.02em;
				text-transform: uppercase;
				margin: 0 0 0.6rem;
			}

			.profile-text {
				color: var(--text-secondary);
				line-height: 1.6;
				font-size: 0.98rem;
			}

			.card-gloss {
				position: relative;
				overflow: hidden;
			}

			.card-gloss::before {
				content: "";
				position: absolute;
				inset: 0;
				background: radial-gradient(circle at 80% 20%, var(--mist-soft) 0%, transparent 55%);
				pointer-events: none;
			}

			@keyframes accentShine {
				0% {
					left: -38%;
					opacity: 0;
				}
				12% {
					opacity: 1;
				}
				40% {
					left: 118%;
					opacity: 0;
				}
				100% {
					left: 118%;
					opacity: 0;
				}
			}
		</style>
	</head>
	<body>
		{showChrome ? <SiteHeader /> : null}
		<slot />
		{showChrome ? <SiteFooter /> : null}

		<script>
			import { getSupabase } from "../lib/supabaseBrowser";

			async function bindAuthNav() {
				const supabase = getSupabase();
				const guest = document.getElementById("authNavGuest");
				const userEl = document.getElementById("authNavUser");
				const nameEl = document.getElementById("authDisplayName");
				const btn = document.getElementById("authLogoutBtn");
				if (!guest || !userEl) return;

				function setMoreMenuAuth(show) {
					document.querySelectorAll("a.dropdown-account").forEach((el) => {
						if (el instanceof HTMLElement) el.hidden = !show;
					});
					document.querySelectorAll(".dropdown-rule").forEach((el) => {
						if (el instanceof HTMLElement) el.hidden = !show;
					});
				}

				async function refresh() {
					if (!supabase) {
						guest.hidden = false;
						userEl.hidden = true;
						setMoreMenuAuth(true);
						return;
					}
					const {
						data: { session },
					} = await supabase.auth.getSession();
					if (session?.user) {
						guest.hidden = true;
						userEl.hidden = false;
						setMoreMenuAuth(false);
						const meta = session.user.user_metadata ?? {};
						if (nameEl) {
							nameEl.textContent =
								(meta.name || meta.username || session.user.email || "").toString();
						}
					} else {
						guest.hidden = false;
						userEl.hidden = true;
						setMoreMenuAuth(true);
					}
				}

				await refresh();
				if (supabase) {
					supabase.auth.onAuthStateChange(() => {
						refresh();
					});
				}
				if (btn && !btn.dataset.bound) {
					btn.dataset.bound = "1";
					btn.addEventListener("click", async () => {
						if (supabase) await supabase.auth.signOut();
						await refresh();
						if (!["/login", "/register"].includes(location.pathname)) {
							window.location.href = "/home";
						}
					});
				}
			}

			document.addEventListener("DOMContentLoaded", bindAuthNav);
		</script>

		<script>
			(() => {
				const header = document.querySelector(".site-header");
				if (!(header instanceof HTMLElement)) return;

				const update = () => {
					header.classList.toggle("scrolled", window.scrollY > 18);
				};

				update();
				window.addEventListener("scroll", update, { passive: true });
			})();
		</script>

		<script>
			(() => {
				const items = document.querySelectorAll("[data-reveal]");
				if (!items.length) return;

				const obs = new IntersectionObserver(
					(entries) => {
						for (const e of entries) {
							if (e.isIntersecting) {
								e.target.classList.add("is-visible");
								obs.unobserve(e.target);
							}
						}
					},
					{ threshold: 0.12 }
				);

				items.forEach((el) => obs.observe(el));
			})();
		</script>
	</body>
</html>
