---
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
}

const {
  title = 'Paramount World Records — Recognizing the Extraordinary',
  description = 'The world\'s most prestigious record-certification authority. Submit your record attempt, verify certificates, and join a global legacy of extraordinary achievement.',
  ogImage = '/og-image.jpg',
  canonicalURL = Astro.url.href,
} = Astro.props;

const siteName = 'Paramount World Records';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet" />

    <style is:global>
      :root {
        --navy: #0A1D37;
        --gold: #C5A059;
      }
      body {
        background-color: var(--navy);
        color: white;
        margin: 0;
        font-family: 'Source Sans 3', sans-serif;
      }
      h1, h2, h3, .font-display {
        font-family: 'Cormorant Garamond', serif;
      }
    </style>
  </head>

  <body>
    <slot />
  </body>
</html>
