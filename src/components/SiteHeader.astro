---
const links = {
	about: "/about",
	founders: "/founders",
	apply: "/apply",
	departments: "/departments",
	vision: "/vision-mission",
	achievers: "/achievers",
	press: "/press-media",
	gallery: "/gallery",
	records: "/records",
	clients: "/clients",
	work: "/work",
	contact: "/contact",
};
---

<header class="site-header site-header-redesign">
	<div class="container header-shell">
		<a class="brand" href="/home">
			<img src="/images/logo.png" alt="Paramount World Records logo" />
			<span>Paramount World Records</span>
		</a>

		<nav class="top-nav" aria-label="Primary">
			<a href={links.about}>About</a>
			<a href={links.founders}>Founders</a>
			<a href={links.apply}>Apply</a>
			<a href={links.contact}>Contact</a>
		</nav>

		<div class="header-actions">
			<span id="authNavGuest" class="auth-nav-guest">
				<a href="/register" class="nav-pill nav-pill-muted">Register</a>
				<a href="/login" class="nav-pill nav-pill-primary">Login</a>
			</span>
			<span id="authNavUser" class="auth-nav-user" hidden>
				<span class="auth-welcome"><strong id="authDisplayName"></strong></span>
				<button type="button" id="authLogoutBtn" class="auth-logout">Logout</button>
			</span>
			<details class="menu">
				<summary>More</summary>
				<div class="dropdown" role="menu" aria-label="More pages">
					<a href="/register" class="dropdown-account">Register</a>
					<a href="/login" class="dropdown-account">Login</a>
					<hr class="dropdown-rule" />
					<a href={links.departments}>Process</a>
					<a href={links.vision}>Vision &amp; Mission</a>
					<a href={links.achievers}>Achievers</a>
					<a href={links.press}>Press &amp; Media</a>
					<a href={links.gallery}>Gallery</a>
					<a href={links.records}>Records</a>
					<a href={links.clients}>Clients</a>
					<a href={links.work}>Work With Us</a>
					<a href="/faq">FAQ</a>
				</div>
			</details>
		</div>
	</div>
</header>

<style>
	.site-header-redesign {
		background: rgba(15, 42, 30, 0.22);
		border-bottom: 0.5px solid rgba(241, 213, 146, 0.42);
		backdrop-filter: blur(10px);
	}

	.site-header-redesign.scrolled {
		background: #123d28;
		border-bottom-color: rgba(241, 213, 146, 0.55);
	}

	.header-shell {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1.15rem;
		padding: 0.72rem 0;
	}

	.site-header-redesign .brand {
		gap: 0.5rem;
		letter-spacing: 0.05em;
		font-size: 0.72rem;
	}

	.site-header-redesign .brand img {
		height: 28px;
	}

	.site-header-redesign .top-nav {
		display: flex;
		justify-content: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.site-header-redesign .top-nav a,
	.site-header-redesign .menu summary {
		font-size: 0.84rem;
		color: #f8e8bc;
		opacity: 0.92;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		background: linear-gradient(
			180deg,
			var(--gloss-top) 0%,
			var(--gloss-mid) 49%,
			var(--gloss-contrast) 51%,
			var(--gloss-base) 100%
		);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		-webkit-text-stroke: 0.25px var(--gloss-stroke-nav);
		text-shadow:
			0 1px 0 rgba(255, 255, 255, 0.16),
			0 5px 9px rgba(0, 0, 0, 0.28);
	}

	.header-actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.6rem;
	}

	.nav-pill {
		display: inline-flex;
		align-items: center;
		padding: 0.48rem 0.82rem;
		border-radius: 999px;
		font-size: 0.71rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		text-decoration: none;
	}

	.nav-pill-muted {
		border: 0.5px solid rgba(241, 213, 146, 0.7);
		color: #ffd700;
		background: rgba(255, 255, 255, 0.04);
		text-shadow: 0 1px 0 rgba(255, 255, 255, 0.12), 0 3px 6px rgba(0, 0, 0, 0.2);
	}

	.nav-pill-muted:hover {
		background: rgba(255, 255, 255, 0.08);
	}

	.nav-pill-primary {
		color: #0c1b2d;
		background: linear-gradient(45deg, #d4af37, #f1d592);
		box-shadow: 0 0 18px rgba(212, 175, 55, 0.3);
		text-shadow: none;
	}

	.auth-welcome {
		background: linear-gradient(
			180deg,
			var(--gloss-top) 0%,
			var(--gloss-mid) 49%,
			var(--gloss-contrast) 51%,
			var(--gloss-base) 100%
		);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		-webkit-text-stroke: 0.2px var(--gloss-stroke-nav);
		text-shadow: 0 1px 0 rgba(255, 255, 255, 0.14), 0 5px 8px rgba(0, 0, 0, 0.28);
	}

	.auth-logout {
		padding: 0.42rem 0.72rem;
		border-radius: 999px;
		font-size: 0.74rem;
	}

	.site-header-redesign .menu {
		position: relative;
	}

	.site-header-redesign .dropdown {
		top: 1.7rem;
		right: 0;
		background: linear-gradient(180deg, rgba(15, 42, 30, 0.97) 0%, rgba(12, 34, 24, 0.92) 100%);
		border: 0.5px solid rgba(241, 213, 146, 0.45);
	}

	.dropdown-rule {
		border: none;
		border-top: 0.5px solid rgba(241, 213, 146, 0.35);
		margin: 0.25rem 0;
	}

	.dropdown-account {
		font-weight: 600;
		color: #fff2c7 !important;
	}

	@media (max-width: 1050px) {
		.header-shell {
			grid-template-columns: 1fr;
			justify-items: start;
			gap: 0.55rem;
		}

		.site-header-redesign .top-nav {
			justify-content: flex-start;
			gap: 0.75rem;
		}

		.header-actions {
			width: 100%;
			justify-content: flex-start;
		}
	}
</style>
