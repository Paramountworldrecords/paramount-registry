---
const links = {
	about: "/about",
	founders: "/founders",
	apply: "/apply",
	departments: "/departments",
	vision: "/vision-mission",
	achievers: "/achievers",
	press: "/press-media",
	gallery: "/gallery",
	records: "/records",
	clients: "/clients",
	work: "/work",
	contact: "/contact",
};
---

<header class="site-header site-header-redesign">
	<div class="container header-shell">
		<a class="brand" href="/home">
			<img src="/images/logo.png" alt="Paramount World Records logo" />
			<span>Paramount World Records</span>
		</a>

		<nav class="top-nav" aria-label="Primary">
			<a href={links.about}>About</a>
			<a href={links.founders}>Founders</a>
			<a href={links.apply}>Apply</a>
			<a href={links.contact}>Contact</a>
		</nav>

		<div class="header-actions">
			<span id="authNavGuest" class="auth-nav-guest">
				<a href="/register" class="nav-pill nav-pill-muted">Register</a>
				<a href="/login" class="nav-pill nav-pill-primary">Login</a>
			</span>
			<span id="authNavUser" class="auth-nav-user" hidden>
				<span class="auth-welcome"><strong id="authDisplayName"></strong></span>
				<button type="button" id="authLogoutBtn" class="auth-logout">Logout</button>
			</span>
			<details class="menu">
				<summary>More</summary>
				<div class="dropdown" role="menu" aria-label="More pages">
					<a href="/register" class="dropdown-account">Register</a>
					<a href="/login" class="dropdown-account">Login</a>
					<hr class="dropdown-rule" />
					<a href={links.departments}>Process</a>
					<a href={links.vision}>Vision &amp; Mission</a>
					<a href={links.achievers}>Achievers</a>
					<a href={links.press}>Press &amp; Media</a>
					<a href={links.gallery}>Gallery</a>
					<a href={links.records}>Records</a>
					<a href={links.clients}>Clients</a>
					<a href={links.work}>Work With Us</a>
					<a href="/faq">FAQ</a>
				</div>
			</details>
		</div>
	</div>
</header>

<style>
	.site-header-redesign {
		background: rgba(8, 8, 8, 0.78);
		border-bottom: 1px solid var(--border-noir, #1f1f1f);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
	}

	.site-header-redesign.scrolled {
		background: rgba(8, 8, 8, 0.94);
		box-shadow: 0 8px 40px rgba(0, 0, 0, 0.55);
	}

	.header-shell {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1.15rem;
		padding: 1rem 0;
	}

	.site-header-redesign .brand {
		gap: 0.55rem;
		letter-spacing: 0.22em;
		font-size: 0.72rem;
		font-weight: 600;
		font-family: var(--font-label, "Montserrat", sans-serif);
		text-transform: uppercase;
		color: #ffffff;
		text-shadow: 0 0 28px rgba(0, 201, 167, 0.35);
	}

	.site-header-redesign .brand:hover {
		color: #ffffff;
		text-shadow: 0 0 36px rgba(0, 201, 167, 0.55);
	}

	.site-header-redesign .brand img {
		height: 30px;
		filter: brightness(1.2) contrast(1.08);
	}

	.site-header-redesign .top-nav {
		display: flex;
		justify-content: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.site-header-redesign .top-nav a,
	.site-header-redesign .menu summary {
		font-size: 0.7rem;
		color: rgba(255, 255, 255, 0.96) !important;
		font-family: var(--font-label, "Montserrat", sans-serif);
		font-weight: 500;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		background: none !important;
		-webkit-background-clip: unset !important;
		background-clip: unset !important;
		-webkit-text-stroke: 0 !important;
		text-shadow: 0 1px 3px rgba(0, 0, 0, 0.65);
		transition: color 0.2s ease, text-shadow 0.2s ease;
	}

	.site-header-redesign .top-nav a:hover,
	.site-header-redesign .menu summary:hover {
		color: #00e6c3 !important;
		text-shadow:
			0 0 22px rgba(0, 201, 167, 0.65),
			0 1px 3px rgba(0, 0, 0, 0.5);
	}

	.header-actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.6rem;
	}

	.nav-pill {
		display: inline-flex;
		align-items: center;
		padding: 0.55rem 1.1rem;
		border-radius: 24px;
		font-size: 0.64rem;
		font-weight: 600;
		font-family: var(--font-label, "Montserrat", sans-serif);
		letter-spacing: 0.2em;
		text-transform: uppercase;
		text-decoration: none;
		transition:
			background 0.2s ease,
			border-color 0.2s ease,
			color 0.2s ease,
			box-shadow 0.2s ease;
	}

	.nav-pill-muted {
		border: 1px solid rgba(0, 201, 167, 0.55);
		color: #ffffff;
		background: rgba(18, 18, 18, 0.85);
		box-shadow: 0 0 20px rgba(0, 201, 167, 0.12);
	}

	.nav-pill-muted:hover {
		border-color: #00e6c3;
		color: #bffff6;
		box-shadow: 0 0 28px rgba(0, 201, 167, 0.35);
	}

	.nav-pill-primary {
		color: #080808;
		background: #ffffff;
		border: 1px solid #ffffff;
		box-shadow:
			0 0 36px rgba(0, 201, 167, 0.4),
			0 0 14px rgba(255, 255, 255, 0.25);
	}

	.nav-pill-primary:hover {
		background: #f0fffc;
		border-color: #bffff6;
		color: #080808;
		box-shadow:
			0 0 44px rgba(0, 201, 167, 0.55),
			0 0 20px rgba(255, 255, 255, 0.35);
	}

	.auth-welcome {
		font-family: var(--font-label, "Montserrat", sans-serif);
		font-size: 0.7rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.88) !important;
		background: none !important;
		-webkit-text-stroke: 0 !important;
		text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
	}

	.auth-welcome strong {
		color: #ffffff;
		font-weight: 600;
		text-shadow: 0 0 20px rgba(0, 201, 167, 0.45);
	}

	.site-header-redesign .auth-logout {
		padding: 0.48rem 0.95rem;
		border-radius: 24px;
		font-size: 0.64rem;
		font-family: var(--font-label, "Montserrat", sans-serif);
		border: 1px solid rgba(0, 201, 167, 0.45);
		color: #ffffff;
		background: rgba(0, 201, 167, 0.14);
		font-weight: 600;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		box-shadow: 0 0 18px rgba(0, 201, 167, 0.15);
		cursor: pointer;
		transition: border-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
	}

	.site-header-redesign .auth-logout:hover {
		border-color: #00e6c3;
		color: #bffff6;
		background: rgba(0, 201, 167, 0.22);
		box-shadow: 0 0 28px rgba(0, 201, 167, 0.35);
	}

	.site-header-redesign .menu {
		position: relative;
	}

	.site-header-redesign .dropdown {
		top: 1.7rem;
		right: 0;
		background: var(--surface-noir, #121212);
		border: 1px solid rgba(0, 201, 167, 0.25);
		border-radius: 24px;
		box-shadow:
			0 24px 56px rgba(0, 0, 0, 0.6),
			0 0 40px rgba(0, 201, 167, 0.08);
	}

	.site-header-redesign .dropdown a {
		color: rgba(255, 255, 255, 0.94) !important;
		font-family: var(--font-label, "Montserrat", sans-serif);
		font-size: 0.68rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		font-weight: 500;
		transition: color 0.15s ease, text-shadow 0.15s ease;
	}

	.site-header-redesign .dropdown a:hover {
		color: #00e6c3 !important;
		text-shadow: 0 0 16px rgba(0, 201, 167, 0.5);
	}

	.dropdown-rule {
		border: none;
		border-top: 1px solid rgba(0, 201, 167, 0.2);
		margin: 0.25rem 0;
	}

	.dropdown-account {
		font-weight: 600;
		color: #ffffff !important;
		text-shadow: 0 0 14px rgba(0, 201, 167, 0.35);
	}

	@media (max-width: 1050px) {
		.header-shell {
			grid-template-columns: 1fr;
			justify-items: start;
			gap: 0.55rem;
		}

		.site-header-redesign .top-nav {
			justify-content: flex-start;
			gap: 0.75rem;
		}

		.header-actions {
			width: 100%;
			justify-content: flex-start;
		}
	}
</style>
