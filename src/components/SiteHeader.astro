---
const links = {
	about: "/about",
	founders: "/founders",
	apply: "/apply",
	departments: "/departments",
	vision: "/vision-mission",
	achievers: "/achievers",
	press: "/press-media",
	gallery: "/gallery",
	records: "/records",
	clients: "/clients",
	work: "/work",
	contact: "/contact",
};
---

<header class="site-header site-header-redesign">
	<div class="container header-shell">
		<a class="brand" href="/home">
			<img src="/images/logo.png" alt="Paramount World Records logo" />
			<span>Paramount World Records</span>
		</a>

		<nav class="top-nav" aria-label="Primary">
			<a href={links.about}>About</a>
			<a href={links.founders}>Founders</a>
			<a href={links.apply}>Apply</a>
			<a href={links.contact}>Contact</a>
		</nav>

		<div class="header-actions">
			<span id="authNavGuest" class="auth-nav-guest">
				<a href="/register" class="nav-pill nav-pill-muted">Register</a>
				<a href="/login" class="nav-pill nav-pill-primary">Login</a>
			</span>
			<span id="authNavUser" class="auth-nav-user" hidden>
				<span class="auth-welcome"><strong id="authDisplayName"></strong></span>
				<button type="button" id="authLogoutBtn" class="auth-logout">Logout</button>
			</span>
			<details class="menu">
				<summary>More</summary>
				<div class="dropdown" role="menu" aria-label="More pages">
					<a href="/register" class="dropdown-account">Register</a>
					<a href="/login" class="dropdown-account">Login</a>
					<hr class="dropdown-rule" />
					<a href={links.departments}>Process</a>
					<a href={links.vision}>Vision &amp; Mission</a>
					<a href={links.achievers}>Achievers</a>
					<a href={links.press}>Press &amp; Media</a>
					<a href={links.gallery}>Gallery</a>
					<a href={links.records}>Records</a>
					<a href={links.clients}>Clients</a>
					<a href={links.work}>Work With Us</a>
					<a href="/faq">FAQ</a>
				</div>
			</details>
		</div>
	</div>
</header>

<style>
	.site-header-redesign {
		background: rgba(8, 8, 8, 0.78);
		border-bottom: 1px solid var(--border-noir, #1f1f1f);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
	}

	.site-header-redesign.scrolled {
		background: rgba(8, 8, 8, 0.94);
		box-shadow: 0 8px 40px rgba(0, 0, 0, 0.55);
	}

	.header-shell {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1.15rem;
		padding: 1rem 0;
	}

	.site-header-redesign .brand {
		gap: 0.5rem;
		letter-spacing: 0.2em;
		font-size: 0.65rem;
		font-weight: 500;
		font-family: var(--font-label, "Montserrat", sans-serif);
		text-transform: uppercase;
		color: #ffffff;
	}

	.site-header-redesign .brand img {
		height: 28px;
		filter: brightness(1.05);
	}

	.site-header-redesign .top-nav {
		display: flex;
		justify-content: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.site-header-redesign .top-nav a,
	.site-header-redesign .menu summary {
		font-size: 0.68rem;
		color: rgba(255, 255, 255, 0.72) !important;
		font-family: var(--font-label, "Montserrat", sans-serif);
		font-weight: 300;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		background: none !important;
		-webkit-background-clip: unset !important;
		background-clip: unset !important;
		-webkit-text-stroke: 0 !important;
		text-shadow: none !important;
	}

	.site-header-redesign .top-nav a:hover,
	.site-header-redesign .menu summary:hover {
		color: #ffffff !important;
	}

	.header-actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.6rem;
	}

	.nav-pill {
		display: inline-flex;
		align-items: center;
		padding: 0.52rem 1rem;
		border-radius: 24px;
		font-size: 0.62rem;
		font-weight: 500;
		font-family: var(--font-label, "Montserrat", sans-serif);
		letter-spacing: 0.2em;
		text-transform: uppercase;
		text-decoration: none;
		transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
	}

	.nav-pill-muted {
		border: 1px solid var(--border-noir, #1f1f1f);
		color: rgba(255, 255, 255, 0.85);
		background: var(--surface-noir, #121212);
	}

	.nav-pill-muted:hover {
		border-color: rgba(255, 255, 255, 0.35);
	}

	.nav-pill-primary {
		color: #080808;
		background: #ffffff;
		border: 1px solid #ffffff;
		box-shadow: 0 0 28px rgba(0, 201, 167, 0.15);
	}

	.nav-pill-primary:hover {
		background: rgba(255, 255, 255, 0.9);
		color: #080808;
	}

	.auth-welcome {
		font-family: var(--font-label, "Montserrat", sans-serif);
		font-size: 0.68rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.65) !important;
		background: none !important;
		-webkit-text-stroke: 0 !important;
	}

	.auth-welcome strong {
		color: #ffffff;
		font-weight: 500;
	}

	.auth-logout {
		padding: 0.42rem 0.72rem;
		border-radius: 24px;
		font-size: 0.65rem;
	}

	.site-header-redesign .menu {
		position: relative;
	}

	.site-header-redesign .dropdown {
		top: 1.7rem;
		right: 0;
		background: var(--surface-noir, #121212);
		border: 1px solid var(--border-noir, #1f1f1f);
		border-radius: 24px;
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.55);
	}

	.site-header-redesign .dropdown a {
		color: rgba(255, 255, 255, 0.75) !important;
		font-family: var(--font-label, "Montserrat", sans-serif);
		font-size: 0.68rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		font-weight: 400;
	}

	.site-header-redesign .dropdown a:hover {
		color: #ffffff !important;
	}

	.dropdown-rule {
		border: none;
		border-top: 1px solid var(--border-noir, #1f1f1f);
		margin: 0.25rem 0;
	}

	.dropdown-account {
		font-weight: 500;
		color: #ffffff !important;
	}

	@media (max-width: 1050px) {
		.header-shell {
			grid-template-columns: 1fr;
			justify-items: start;
			gap: 0.55rem;
		}

		.site-header-redesign .top-nav {
			justify-content: flex-start;
			gap: 0.75rem;
		}

		.header-actions {
			width: 100%;
			justify-content: flex-start;
		}
	}
</style>
