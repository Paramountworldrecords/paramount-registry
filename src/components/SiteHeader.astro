---
const links = {
	about: "/about",
	founders: "/founders",
	apply: "/apply",
	departments: "/departments",
	vision: "/vision-mission",
	achievers: "/achievers",
	press: "/press-media",
	gallery: "/gallery",
	records: "/records",
	clients: "/clients",
	work: "/work",
	contact: "/contact",
};
---

<header class="site-header site-header-redesign">
	<div class="container header-shell">
		<a class="brand" href="/home">
			<img src="/images/logo.png" alt="Paramount World Records logo" />
			<span>Paramount World Records</span>
		</a>

		<nav class="top-nav" aria-label="Primary">
			<a href={links.about}>About</a>
			<a href={links.founders}>Founders</a>
			<a href={links.apply}>Apply</a>
			<a href={links.contact}>Contact</a>
		</nav>

		<div class="header-actions">
			<span id="authNavGuest" class="auth-nav-guest">
				<a href="/register" class="nav-pill nav-pill-muted">Register</a>
				<a href="/login" class="nav-pill nav-pill-primary">Login</a>
			</span>
			<span id="authNavUser" class="auth-nav-user" hidden>
				<span class="auth-welcome"><strong id="authDisplayName"></strong></span>
				<button type="button" id="authLogoutBtn" class="auth-logout">Logout</button>
			</span>
			<details class="menu">
				<summary>More</summary>
				<div class="dropdown" role="menu" aria-label="More pages">
					<a href="/register" class="dropdown-account">Register</a>
					<a href="/login" class="dropdown-account">Login</a>
					<hr class="dropdown-rule" />
					<a href={links.departments}>Process</a>
					<a href={links.vision}>Vision &amp; Mission</a>
					<a href={links.achievers}>Achievers</a>
					<a href={links.press}>Press &amp; Media</a>
					<a href={links.gallery}>Gallery</a>
					<a href={links.records}>Records</a>
					<a href={links.clients}>Clients</a>
					<a href={links.work}>Work With Us</a>
					<a href="/faq">FAQ</a>
				</div>
			</details>
		</div>
	</div>
</header>

<style>
	.site-header-redesign {
		background: rgba(228, 228, 222, 0.78);
		border-bottom: 1px solid var(--border-sage, #a3a494);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
	}

	.site-header-redesign.scrolled {
		background: rgba(228, 228, 222, 0.95);
		box-shadow: 0 8px 24px rgba(27, 27, 27, 0.05);
	}

	.header-shell {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1.15rem;
		padding: 1rem 0;
	}

	.site-header-redesign .brand {
		gap: 0.5rem;
		letter-spacing: 0.02em;
		font-size: 0.95rem;
		font-weight: 600;
	}

	.site-header-redesign .brand img {
		height: 28px;
		filter: none;
	}

	.site-header-redesign .top-nav {
		display: flex;
		justify-content: center;
		gap: 1.35rem;
		flex-wrap: wrap;
	}

	.site-header-redesign .top-nav a,
	.site-header-redesign .menu summary {
		font-size: 0.82rem;
		color: var(--text-secondary, #2c2c2c) !important;
		opacity: 1;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		font-weight: 500;
		background: none !important;
		-webkit-background-clip: unset !important;
		background-clip: unset !important;
		-webkit-text-stroke: 0 !important;
		text-shadow: none !important;
	}

	.site-header-redesign .top-nav a:hover,
	.site-header-redesign .menu summary:hover {
		color: var(--text-primary, #1b1b1b) !important;
		opacity: 1;
	}

	.header-actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.6rem;
	}

	.nav-pill {
		display: inline-flex;
		align-items: center;
		padding: 0.48rem 0.95rem;
		border-radius: 2px;
		font-size: 0.68rem;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		text-decoration: none;
		transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
	}

	.nav-pill-muted {
		border: 1px solid var(--border-sage, #a3a494);
		color: var(--text-primary, #1b1b1b);
		background: transparent;
		text-shadow: none;
	}

	.nav-pill-muted:hover {
		background: var(--bg-sage, #c4c5ba);
	}

	.nav-pill-primary {
		color: var(--bg-ivory, #e4e4de);
		background: var(--text-primary, #1b1b1b);
		border: 1px solid var(--text-primary, #1b1b1b);
		box-shadow: 0 8px 24px rgba(27, 27, 27, 0.08);
		text-shadow: none;
	}

	.nav-pill-primary:hover {
		background: var(--text-secondary, #2c2c2c);
		border-color: var(--text-secondary, #2c2c2c);
		color: var(--bg-ivory, #e4e4de);
	}

	.auth-welcome {
		background: none !important;
		-webkit-background-clip: unset !important;
		color: var(--text-secondary, #2c2c2c) !important;
		-webkit-text-stroke: 0 !important;
		text-shadow: none !important;
	}

	.auth-welcome strong {
		font-weight: 600;
		color: var(--text-primary, #1b1b1b);
	}

	.auth-logout {
		padding: 0.42rem 0.72rem;
		border-radius: 2px;
		font-size: 0.74rem;
	}

	.site-header-redesign .menu {
		position: relative;
	}

	.site-header-redesign .dropdown {
		top: 1.7rem;
		right: 0;
		background: var(--bg-ivory, #e4e4de);
		border: 1px solid var(--border-sage, #a3a494);
		box-shadow: 0 16px 48px rgba(27, 27, 27, 0.07);
	}

	.site-header-redesign .dropdown a {
		color: var(--text-secondary, #2c2c2c) !important;
		font-size: 0.8rem;
		letter-spacing: 0.06em;
	}

	.site-header-redesign .dropdown a:hover {
		color: var(--text-primary, #1b1b1b) !important;
	}

	.dropdown-rule {
		border: none;
		border-top: 1px solid var(--border-sage, #a3a494);
		margin: 0.25rem 0;
	}

	.dropdown-account {
		font-weight: 600;
		color: var(--text-primary, #1b1b1b) !important;
	}

	@media (max-width: 1050px) {
		.header-shell {
			grid-template-columns: 1fr;
			justify-items: start;
			gap: 0.55rem;
		}

		.site-header-redesign .top-nav {
			justify-content: flex-start;
			gap: 0.75rem;
		}

		.header-actions {
			width: 100%;
			justify-content: flex-start;
		}
	}
</style>
