---
const links = {
	about: "/about",
	founders: "/founders",
	apply: "/apply",
	departments: "/departments",
	vision: "/vision-mission",
	achievers: "/achievers",
	press: "/press-media",
	gallery: "/gallery",
	records: "/records",
	clients: "/clients",
	work: "/work",
	contact: "/contact",
};
---

<header class="site-header site-header-redesign">
	<div class="container header-shell">
		<a class="brand" href="/home">
			<img src="/images/logo.png" alt="Paramount World Records logo" />
			<span>Paramount World Records</span>
		</a>

		<nav class="top-nav" aria-label="Primary">
			<a href={links.about}>About</a>
			<a href={links.founders}>Founders</a>
			<a href={links.apply}>Apply</a>
			<a href={links.contact}>Contact</a>
		</nav>

		<div class="header-actions">
			<span id="authNavGuest" class="auth-nav-guest">
				<a href="/register" class="nav-pill nav-pill-muted">Register</a>
				<a href="/login" class="nav-pill nav-pill-primary">Login</a>
			</span>
			<span id="authNavUser" class="auth-nav-user" hidden>
				<span class="auth-welcome"><strong id="authDisplayName"></strong></span>
				<button type="button" id="authLogoutBtn" class="auth-logout">Logout</button>
			</span>
			<details class="menu">
				<summary>More</summary>
				<div class="dropdown" role="menu" aria-label="More pages">
					<a href="/register" class="dropdown-account">Register</a>
					<a href="/login" class="dropdown-account">Login</a>
					<hr class="dropdown-rule" />
					<a href={links.departments}>Process</a>
					<a href={links.vision}>Vision &amp; Mission</a>
					<a href={links.achievers}>Achievers</a>
					<a href={links.press}>Press &amp; Media</a>
					<a href={links.gallery}>Gallery</a>
					<a href={links.records}>Records</a>
					<a href={links.clients}>Clients</a>
					<a href={links.work}>Work With Us</a>
					<a href="/faq">FAQ</a>
				</div>
			</details>
		</div>
	</div>
</header>

<style>
	.site-header-redesign {
		background: rgba(255, 255, 255, 0.78);
		border-bottom: 1px solid var(--border-subtle, #e2e8f0);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
	}

	.site-header-redesign.scrolled {
		background: rgba(255, 255, 255, 0.96);
		box-shadow: 0 8px 32px rgba(15, 23, 42, 0.06);
	}

	.header-shell {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1.15rem;
		padding: 1rem 0;
	}

	.site-header-redesign .brand {
		gap: 0.55rem;
		letter-spacing: -0.02em;
		font-size: 1rem;
		font-weight: 700;
		font-family: var(--font-label, "Plus Jakarta Sans", sans-serif);
		text-transform: none;
		color: var(--text-primary, #0f172a);
		text-shadow: none;
	}

	.site-header-redesign .brand:hover {
		color: var(--accent, #4f46e5);
	}

	.site-header-redesign .brand img {
		height: 30px;
		filter: none;
	}

	.site-header-redesign .top-nav {
		display: flex;
		justify-content: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.site-header-redesign .top-nav a,
	.site-header-redesign .menu summary {
		font-size: 0.875rem;
		color: var(--text-secondary, #475569) !important;
		font-family: var(--font-label, "Plus Jakarta Sans", sans-serif);
		font-weight: 500;
		letter-spacing: 0;
		text-transform: none;
		background: none !important;
		-webkit-background-clip: unset !important;
		background-clip: unset !important;
		-webkit-text-stroke: 0 !important;
		text-shadow: none;
		transition: color 0.2s ease;
	}

	.site-header-redesign .top-nav a:hover,
	.site-header-redesign .menu summary:hover {
		color: var(--accent, #4f46e5) !important;
	}

	.header-actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.6rem;
	}

	.nav-pill {
		display: inline-flex;
		align-items: center;
		padding: 0.55rem 1.15rem;
		border-radius: 9999px;
		font-size: 0.875rem;
		font-weight: 600;
		font-family: var(--font-label, "Plus Jakarta Sans", sans-serif);
		letter-spacing: 0;
		text-transform: none;
		text-decoration: none;
		transition:
			background 0.2s ease,
			border-color 0.2s ease,
			color 0.2s ease,
			box-shadow 0.2s ease;
	}

	.nav-pill-muted {
		border: 1px solid var(--border-subtle, #e2e8f0);
		color: var(--text-primary, #0f172a);
		background: var(--surface-card, #fff);
		box-shadow: var(--shadow-soft-sm, 0 4px 24px rgba(15, 23, 42, 0.06));
	}

	.nav-pill-muted:hover {
		border-color: var(--accent, #4f46e5);
		color: var(--accent, #4f46e5);
		background: var(--accent-soft, rgba(79, 70, 229, 0.1));
	}

	.nav-pill-primary {
		color: #fff;
		background: var(--accent, #4f46e5);
		border: 1px solid var(--accent, #4f46e5);
		box-shadow: 0 8px 24px rgba(79, 70, 229, 0.22);
	}

	.nav-pill-primary:hover {
		background: var(--accent-hover, #4338ca);
		border-color: var(--accent-hover, #4338ca);
		color: #fff;
		box-shadow: 0 10px 28px rgba(79, 70, 229, 0.28);
	}

	.auth-welcome {
		font-family: var(--font-label, "Plus Jakarta Sans", sans-serif);
		font-size: 0.875rem;
		letter-spacing: 0;
		text-transform: none;
		color: var(--text-secondary, #475569) !important;
		background: none !important;
		-webkit-text-stroke: 0 !important;
		text-shadow: none;
	}

	.auth-welcome strong {
		color: var(--text-primary, #0f172a);
		font-weight: 600;
		text-shadow: none;
	}

	.site-header-redesign .auth-logout {
		padding: 0.48rem 0.95rem;
		border-radius: 9999px;
		font-size: 0.8125rem;
		font-family: var(--font-label, "Plus Jakarta Sans", sans-serif);
		border: 1px solid var(--border-subtle, #e2e8f0);
		color: var(--text-primary, #0f172a);
		background: var(--surface-muted, #f8fafc);
		font-weight: 600;
		letter-spacing: 0;
		text-transform: none;
		box-shadow: none;
		cursor: pointer;
		transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
	}

	.site-header-redesign .auth-logout:hover {
		border-color: var(--accent, #4f46e5);
		color: var(--accent, #4f46e5);
		background: var(--accent-soft, rgba(79, 70, 229, 0.1));
	}

	.site-header-redesign .menu {
		position: relative;
	}

	.site-header-redesign .dropdown {
		top: 1.7rem;
		right: 0;
		background: var(--surface-card, #fff);
		border: 1px solid var(--border-subtle, #e2e8f0);
		border-radius: var(--radius-card, 16px);
		box-shadow: var(--shadow-soft, 0 24px 56px rgba(15, 23, 42, 0.08));
	}

	.site-header-redesign .dropdown a {
		color: var(--text-secondary, #475569) !important;
		font-family: var(--font-label, "Plus Jakarta Sans", sans-serif);
		font-size: 0.8125rem;
		letter-spacing: 0;
		text-transform: none;
		font-weight: 500;
		transition: color 0.15s ease;
	}

	.site-header-redesign .dropdown a:hover {
		color: var(--accent, #4f46e5) !important;
		text-shadow: none;
	}

	.dropdown-rule {
		border: none;
		border-top: 1px solid var(--border-subtle, #e2e8f0);
		margin: 0.25rem 0;
	}

	.dropdown-account {
		font-weight: 600;
		color: var(--text-primary, #0f172a) !important;
	}

	@media (max-width: 1050px) {
		.header-shell {
			grid-template-columns: 1fr;
			justify-items: start;
			gap: 0.55rem;
		}

		.site-header-redesign .top-nav {
			justify-content: flex-start;
			gap: 0.75rem;
		}

		.header-actions {
			width: 100%;
			justify-content: flex-start;
		}
	}
</style>
