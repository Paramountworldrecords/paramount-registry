---
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="container footer-links">
		<a href="/sitemap">Sitemap</a>
		<a href="/faq">FAQ</a>
		<a href="/cookies">Cookies Policy</a>
		<a href="/privacy">Privacy Policy</a>
		<a href="/terms">Terms of Use</a>
	</div>
	<div class="container footer-gloss" role="group" aria-label="Gloss text style">
		<span class="footer-gloss-label">Gloss style</span>
		<div class="footer-gloss-toggle">
			<button type="button" class="footer-gloss-btn" data-gloss-theme-btn="gold-platinum">Gold + Platinum</button>
			<button type="button" class="footer-gloss-btn" data-gloss-theme-btn="white-black">White + Black</button>
		</div>
	</div>
	<div class="container footer-copy">© {year} Paramount World Records. All rights reserved.</div>
</footer>

