---
const steps = [
	{
		title: "Application & screening",
		text: "Structured intake, eligibility checks, and alignment with our published attempt categories.",
	},
	{
		title: "Rules & protocol",
		text: "Clear attempt guidelines, evidence expectations, and timelines issued before you commit resources.",
	},
	{
		title: "Evidence & adjudication",
		text: "Witnessing, documentation, and expert review so outcomes rest on verifiable fact—not opinion.",
	},
	{
		title: "Certification",
		text: "Formal recognition when standards are met, with registry-ready documentation.",
	},
	{
		title: "Publication",
		text: "Listing and coordinated communications so qualified achievements enter the public record with dignity.",
	},
];
---

<section class="authority-strip" aria-labelledby="cert-process-title">
	<div class="container">
		<div class="authority-card panel" data-reveal>
			<p class="tag authority-tag" id="cert-process-title">Certification pathway</p>
			<h2 class="authority-heading">From application to publication</h2>
			<p class="authority-deck">
				Authority is process: predictable stages, written standards, and adjudication you can trace.
			</p>
			<ol class="authority-steps">
				{
					steps.map((s, i) => (
						<li class="authority-step">
							<span class="authority-step-num" aria-hidden="true">
								{(i + 1).toString().padStart(2, "0")}
							</span>
							<div class="authority-step-body">
								<h3 class="authority-step-title">{s.title}</h3>
								<p class="authority-step-text">{s.text}</p>
							</div>
						</li>
					))
				}
			</ol>
			<p class="authority-links">
				<a href="/departments">Departments &amp; full process</a>
				<span class="authority-links-sep" aria-hidden="true">·</span>
				<a href="/faq">Frequently asked questions</a>
			</p>
		</div>
	</div>
</section>

<style>
	.authority-strip {
		padding: clamp(1rem, 3vw, 2rem) 0 clamp(4rem, 10vw, 6rem);
	}

	.authority-card {
		padding: clamp(2rem, 4vw, 3rem);
		border-radius: 2px;
	}

	.authority-tag {
		margin-bottom: 0.65rem;
	}

	.authority-heading {
		font-size: clamp(1.5rem, 2.8vw, 2rem);
		margin-bottom: 0.75rem;
		line-height: 1.25;
		text-transform: none;
		font-family: var(--font-display, "Playfair Display", Georgia, serif);
		font-weight: 600;
		color: var(--text-primary, #1b1b1b);
	}

	.authority-deck {
		margin: 0 0 2.5rem;
		max-width: 42rem;
		color: var(--text-secondary, #2c2c2c);
		line-height: 1.8;
		font-size: 1rem;
	}

	.authority-steps {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1.25rem;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
	}

	.authority-step {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
		padding: 1.2rem 1.25rem;
		background: var(--bg-ivory, #e4e4de);
		border: 1px solid var(--border-sage, #a3a494);
		border-radius: 2px;
		box-shadow: 0 8px 24px rgba(27, 27, 27, 0.04);
	}

	.authority-step-num {
		flex-shrink: 0;
		font-family: var(--font-display, Georgia, serif);
		font-size: 1.25rem;
		font-weight: 600;
		color: var(--text-secondary, #2c2c2c);
		line-height: 1;
		opacity: 0.85;
		letter-spacing: 0.02em;
	}

	.authority-step-body {
		min-width: 0;
	}

	.authority-step-title {
		font-size: 0.98rem;
		margin: 0 0 0.4rem;
		color: var(--text-primary, #1b1b1b);
		font-weight: 600;
		letter-spacing: 0.01em;
	}

	.authority-step-text {
		margin: 0;
		font-size: 0.88rem;
		line-height: 1.65;
		color: var(--text-secondary, #2c2c2c);
	}

	.authority-links {
		margin: 2rem 0 0;
		font-size: 0.72rem;
		color: var(--text-secondary, #2c2c2c);
		text-transform: uppercase;
		letter-spacing: 0.16em;
	}

	.authority-links-sep {
		margin: 0 0.5rem;
		opacity: 0.45;
	}

	.authority-links a {
		font-weight: 600;
		color: var(--text-primary, #1b1b1b);
		border-bottom: 1px solid var(--border-sage, #a3a494);
		padding-bottom: 0.1rem;
	}

	.authority-links a:hover {
		opacity: 1;
		border-bottom-color: var(--text-primary, #1b1b1b);
	}
</style>
