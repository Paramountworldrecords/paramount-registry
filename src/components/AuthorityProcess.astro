---
const steps = [
	{
		title: "Application & screening",
		text: "Structured intake, eligibility checks, and alignment with our published attempt categories.",
	},
	{
		title: "Rules & protocol",
		text: "Clear attempt guidelines, evidence expectations, and timelines issued before you commit resources.",
	},
	{
		title: "Evidence & adjudication",
		text: "Witnessing, documentation, and expert review so outcomes rest on verifiable fact—not opinion.",
	},
	{
		title: "Certification",
		text: "Formal recognition when standards are met, with registry-ready documentation.",
	},
	{
		title: "Publication",
		text: "Listing and coordinated communications so qualified achievements enter the public record with dignity.",
	},
];
---

<section class="authority-strip" aria-labelledby="cert-process-title">
	<div class="container">
		<div class="authority-card panel" data-reveal>
			<p class="tag authority-tag" id="cert-process-title">Certification pathway</p>
			<h2 class="authority-heading">
				From application to publication<span class="stoplight" aria-hidden="true">.</span>
			</h2>
			<p class="authority-deck">
				Authority is process: predictable stages, written standards, and adjudication you can trace.
			</p>
			<ol class="authority-steps">
				{
					steps.map((s, i) => (
						<li class="authority-step">
							<span class="authority-step-num" aria-hidden="true">
								{(i + 1).toString().padStart(2, "0")}
							</span>
							<div class="authority-step-body">
								<h3 class="authority-step-title">{s.title}</h3>
								<p class="authority-step-text">{s.text}</p>
							</div>
						</li>
					))
				}
			</ol>
			<p class="authority-links">
				<a href="/departments">Departments &amp; full process</a>
				<span class="authority-links-sep" aria-hidden="true">·</span>
				<a href="/faq">Frequently asked questions</a>
			</p>
		</div>
	</div>
</section>

<style>
	.authority-strip {
		padding: clamp(1rem, 3vw, 2rem) 0 clamp(4rem, 10vw, 6rem);
	}

	.authority-card {
		padding: clamp(2.25rem, 5vw, 3.5rem);
		border-radius: 24px;
		position: relative;
		overflow: hidden;
	}

	.authority-card::before {
		content: "";
		position: absolute;
		inset: 0;
		background: radial-gradient(circle at 20% 0%, rgba(79, 70, 229, 0.07) 0%, transparent 45%);
		pointer-events: none;
	}

	.authority-card > * {
		position: relative;
		z-index: 1;
	}

	.authority-tag {
		margin-bottom: 0.85rem;
		text-align: center;
	}

	.authority-heading {
		font-family: var(--font-hero, "Plus Jakarta Sans", sans-serif);
		font-size: clamp(1.65rem, 4vw, 2.35rem);
		font-weight: 800;
		margin-bottom: 1rem;
		line-height: 1.08;
		text-transform: none;
		letter-spacing: -0.03em;
		color: var(--text-primary, #0f172a);
		text-align: center;
		max-width: 22ch;
		margin-left: auto;
		margin-right: auto;
	}

	.authority-deck {
		margin: 0 auto 2.75rem;
		max-width: 40rem;
		color: var(--text-secondary, #475569);
		line-height: 1.8;
		font-size: 0.98rem;
		text-align: center;
	}

	.authority-steps {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1.25rem;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
	}

	.authority-step {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
		padding: 1.35rem 1.4rem;
		background: var(--surface-muted, #f8fafc);
		border: 1px solid var(--border-subtle, #e2e8f0);
		border-radius: var(--radius-card, 16px);
		box-shadow: var(--shadow-soft-sm, 0 4px 24px rgba(15, 23, 42, 0.06));
	}

	.authority-step-num {
		flex-shrink: 0;
		font-family: var(--font-hero, "Plus Jakarta Sans", sans-serif);
		font-size: 1.35rem;
		font-weight: 800;
		color: var(--accent, #4f46e5);
		line-height: 1;
		letter-spacing: -0.02em;
		opacity: 0.85;
	}

	.authority-step-body {
		min-width: 0;
	}

	.authority-step-title {
		font-family: var(--font-label, "Plus Jakarta Sans", sans-serif);
		font-size: 1rem;
		margin: 0 0 0.45rem;
		color: var(--text-primary, #0f172a);
		font-weight: 700;
		letter-spacing: -0.02em;
		text-transform: none;
	}

	.authority-step-text {
		margin: 0;
		font-size: 0.86rem;
		line-height: 1.65;
		color: var(--text-secondary, #475569);
	}

	.authority-links {
		margin: 2.25rem 0 0;
		font-size: 0.8125rem;
		font-family: var(--font-label, "Plus Jakarta Sans", sans-serif);
		color: var(--text-muted, #94a3b8);
		text-transform: none;
		letter-spacing: 0;
		text-align: center;
	}

	.authority-links-sep {
		margin: 0 0.5rem;
		opacity: 0.4;
	}

	.authority-links a {
		font-weight: 600;
		color: var(--accent, #4f46e5);
		border-bottom: 1px solid rgba(79, 70, 229, 0.3);
		padding-bottom: 0.12rem;
	}

	.authority-links a:hover {
		opacity: 1;
		border-bottom-color: var(--accent-hover, #4338ca);
		color: var(--accent-hover, #4338ca);
	}
</style>
