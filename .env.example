# Copy to .env and fill from Supabase: Project Settings -> API
# Use the anon (public) key in the browser — never commit a service role key.

PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (Vercel Environment Variables — not PUBLIC): store applications + send email
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (https://resend.com): API key + verified From address for your domain
RESEND_API_KEY=re_xxxx
# Example after domain verify: "Paramount World Records <noreply@paramountworldrecords.com>"
# For Resend testing only: onboarding@resend.dev
RESEND_FROM=Paramount World Records <onboarding@resend.dev>
